    // 1. Versuch: Topologie-basierte Kette (echte Bauteil-Nachbarschaft)
    let chain = buildChainFromTopology(partA, partB);
    let isGeneric = false;
    if(!chain){
      // 2. Versuch: explizite Vorlage
      const tmpl = findLocalTemplate(partA, partB);
