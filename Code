// ══ INNOVATION 1: TOLERANZ-ALLOKATION (Reverse-Solve) ════════════════
// Gegeben Ziel-Toleranz (chainSpec) → optimale Einzeltoleranzen je Beitragsleister.
// Zwei Strategien: gleichverteilt (gleicher Anteil) vs. proportional (nach aktuellem Beitrag,
// bewahrt das Verhältnis – günstigere/schwierige Glieder bleiben relativ gleich belastet).
function renderAllocationCard(rssNow){
  if(!chainSpec || !links.length) return '';
  // Ziel: RSS-Halbspanne soll specTol entsprechen (im gewählten σ-Modus).
  // rssNow ist ±3σ-Halbspanne. Ziel-rss3:
  const targetRss3 = sigmaMode===4 ? chainSpec.tol*3/4 : chainSpec.tol;
  const n = links.length;
  // Aktuelle Halbspannen
  const halfs = links.map(l=>(l.upper-l.lower)/2);
  const dfs = links.map(l=>l.distributionFactor||1);
  // Strategie A – Gleichverteilung: jeder gleiche Varianz, Σ(t_i·df_i)² = targetRss3²
  // t_equal·df gleich für alle → n·(t·df)² = targetRss3² → t = targetRss3/(df·√n)
  // (vereinfacht mit gemitteltem df)
  const equalShare = targetRss3/Math.sqrt(n);
  const allocEqual = dfs.map(df=>equalShare/df);
  // Strategie B – Proportional zum aktuellen Beitrag (skaliert die ganze Kette)
  const scale = rssNow>0 ? targetRss3/rssNow : 1;
  const allocProp = halfs.map(h=>h*scale);
  const feasible = targetRss3 >= rssNow*0.999; // Ziel lockerer als aktuell?
  const col = feasible ? '#1DAA6A' : '#F5A623';
  return `
    <div class="card" style="border-left:3px solid var(--blue)">
      <div class="card-title"><svg viewBox="0 0 24 24" fill="none"><path d="M12 3v18M3 12h18M5.6 5.6l12.8 12.8M18.4 5.6L5.6 18.4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>Toleranz-Allokation (Reverse-Solve)</div>
      <div style="font-size:13px;color:var(--text3);margin-bottom:12px;line-height:1.5">Welche Einzeltoleranz braucht jeder Beitragsleister, damit die Vorgabe ±${fmt(chainSpec.tol,1)} mm (${sigmaMode}σ) erreicht wird? ${feasible?'Die Vorgabe ist mit den aktuellen Gliedern erreichbar – Allokation zeigt den Spielraum.':'<span style="color:#F5A623;font-weight:600">Achtung: Vorgabe ist enger als die aktuelle Kette – die Allokation zeigt die nötige Verschärfung.</span>'}</div>
      <div style="display:grid;grid-template-columns:1fr auto auto;gap:6px 12px;font-size:12px;align-items:center">
        <div style="font-weight:700;color:var(--text3);text-transform:uppercase;font-size:10px;letter-spacing:.5px">Beitragsleister</div>
        <div style="font-weight:700;color:var(--text3);text-transform:uppercase;font-size:10px;letter-spacing:.5px;text-align:right" title="Gleicher Varianzbeitrag für alle">Gleichverteilt</div>
        <div style="font-weight:700;color:var(--text3);text-transform:uppercase;font-size:10px;letter-spacing:.5px;text-align:right" title="Aktuelles Verhältnis beibehalten">Proportional</div>
        ${links.map((l,i)=>`
          <div style="white-space:nowrap;overflow:hidden;text-overflow:ellipsis;color:var(--text2)">${l.type==='montage'?'<span style="color:#4BA3E3">⬢</span> ':''}${l.name}</div>
          <div style="text-align:right;font-family:'JetBrains Mono',monospace;color:${allocEqual[i]<halfs[i]?'#D93025':'#1DAA6A'}">±${fmt(allocEqual[i],1)}</div>
          <div style="text-align:right;font-family:'JetBrains Mono',monospace;color:${allocProp[i]<halfs[i]?'#D93025':'#1DAA6A'}">±${fmt(allocProp[i],1)}</div>
        `).join('')}
      </div>
      <div style="display:flex;gap:8px;margin-top:12px">
        <button class="btn ghost sm" style="flex:1" onclick="applyAllocation('equal')">Gleichverteilt übernehmen</button>
        <button class="btn ghost sm" style="flex:1" onclick="applyAllocation('prop')">Proportional übernehmen</button>
      </div>
      <div style="font-size:11px;color:var(--text3);margin-top:8px;line-height:1.5">🟢 lockerer · 🔴 enger als aktuell. Werte auf 0,1 mm gerundet (Anzeige-Konvention) – exakte Allokation kann minimal abweichen. Quelle: Toleranzallokation nach Creveling/Drake, gleichverteilt = naiv, proportional = sensitivitätserhaltend.</div>
    </div>`;
}
function applyAllocation(mode){
  if(!chainSpec || !links.length) return;
  const rssNow = Math.sqrt(links.reduce((a,l)=>a+Math.pow((l.upper-l.lower)/2*(l.distributionFactor||1),2),0));
  const targetRss3 = sigmaMode===4 ? chainSpec.tol*3/4 : chainSpec.tol;
  const n = links.length;
  links.forEach(l=>{
    const df=l.distributionFactor||1;
    let t;
    if(mode==='equal'){ t = (targetRss3/Math.sqrt(n))/df; }
    else { const scale = rssNow>0?targetRss3/rssNow:1; t=(l.upper-l.lower)/2*scale; }
    t = Math.round(t*10)/10;
    l.upper = t; l.lower = -t;
  });
  renderLinks(); calcTC();
}

// ══ INNOVATION 2: YIELD- & PPM-PROGNOSE mit Ampel-Visualisierung ═════
// Übersetzt die RSS-Streuung in erwartete Gutteil-Rate (Yield), PPM und ein
// anschauliches "von X Fahrzeugen sind Y außerhalb"-Bild. Pro Anforderungsklasse.
function renderYieldCard(rssNow){
  if(!chainSpec) return '';
  const sigma = rssNow/3;                       // 1σ aus ±3σ-Halbspanne
  if(sigma<=0) return '';
  const cpk = chainSpec.tol/(3*sigma);          // zentriert (Cp)
  // PPM mit 1.5σ-Langzeit-Shift (Industriestandard Six Sigma)
  const zShift = cpk*3 - 1.5;
  const ppm = Math.max(0, normCDF(-zShift)*1e6);
  const yieldPct = 100 - ppm/1e4;
  const qty = (typeof getEffectiveQty==='function' ? getEffectiveQty() : null);
  const defectVeh = qty ? Math.round(ppm/1e6*qty) : null;
  // ── Prozessfähigkeits-gewichtete REALE Prognose ──
  // Statt anzunehmen jede Toleranz sei perfekt fähig: nutze typische Serien-Cpk je Prozess.
  // Effektives σ je Glied = Toleranz/(3·cpkProzess); RSS daraus = realistische Streuung.
  let realRss=0, hasProc=false;
  links.forEach(l=>{
    const half=(l.upper-l.lower)/2*(l.distributionFactor||1);
    const mfg=MFG_TOL[l.mfg];
    const cpkP = mfg && mfg.cpkTyp ? mfg.cpkTyp : 1.33;
    if(mfg && mfg.cpkTyp) hasProc=true;
    // reale σ-Halbspanne dieses Glieds bei typischer Prozessfähigkeit
    const realSigmaHalf = half/cpkP*1.33; // skaliert relativ zur Referenz-Cpk 1.33
    realRss += realSigmaHalf*realSigmaHalf;
  });
  realRss=Math.sqrt(realRss);
  const realSigma=realRss/3;
  const realCpk = realSigma>0 ? chainSpec.tol/(3*realSigma) : cpk;
  const realPpm = Math.max(0, normCDF(-(realCpk*3-1.5))*1e6);
  const realDefectVeh = qty ? Math.round(realPpm/1e6*qty) : null;
  // Ampel
  const lvl = cpk>=1.67?'#1DAA6A':cpk>=1.33?'#1DAA6A':cpk>=1.0?'#F5A623':'#D93025';
  const lvlTxt = cpk>=1.67?'Vorserie-fähig (≥1.67)':cpk>=1.33?'Serien-fähig (≥1.33)':cpk>=1.0?'Grenzwertig (1.0–1.33)':'Nicht fähig (<1.0)';
  // Visualisierung: 100 Punkte, davon defekt
  const dotsTotal=100;
  const badDots = Math.min(dotsTotal, Math.max(ppm>0?1:0, Math.round(ppm/1e6*dotsTotal)));
  const realCol = realCpk>=1.33?'#1DAA6A':realCpk>=1.0?'#F5A623':'#D93025';
  return `
    <div class="card" style="border-left:3px solid ${lvl}">
      <div class="card-title"><svg viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5"/><path d="M12 7v5l3 2" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>Yield-Prognose & Prozessfähigkeit</div>
      <div class="row2" style="margin-bottom:12px">
        <div class="metric"><div class="metric-val" style="color:${lvl};font-size:var(--fs-xl)">${cpk.toFixed(2)}</div><div class="metric-lbl">Cpk (ideal/zentriert)</div></div>
        <div class="metric"><div class="metric-val" style="color:${lvl};font-size:var(--fs-xl)">${yieldPct>=99.99?'99.99':yieldPct.toFixed(2)}%</div><div class="metric-lbl">Yield (Gutteile)</div></div>
      </div>
      <div style="background:${lvl}15;border:1px solid ${lvl}40;border-radius:8px;padding:8px 12px;margin-bottom:12px;font-size:13px;font-weight:600;color:${lvl}">${lvlTxt}</div>
      <div style="font-size:12px;color:var(--text3);margin-bottom:6px">Erwartete Fehlerrate: <strong style="color:var(--text)">${Math.round(ppm).toLocaleString('de')} PPM</strong>${defectVeh!==null?` · ≈ <strong style="color:${lvl}">${defectVeh.toLocaleString('de')}</strong> von ${qty.toLocaleString('de')} Fahrzeugen außerhalb`:''}</div>
      <div style="display:grid;grid-template-columns:repeat(20,1fr);gap:2px;margin-top:8px">
        ${Array.from({length:dotsTotal},(_,i)=>`<div style="aspect-ratio:1;border-radius:50%;background:${i<badDots?lvl:'var(--border2)'};opacity:${i<badDots?1:.4}"></div>`).join('')}
      </div>
      <div style="font-size:11px;color:var(--text3);margin-top:6px">Idealfall: zentrierter Prozess, jede Toleranz perfekt fähig (1.5σ-Langzeit-Shift).</div>
      ${hasProc?`
      <div style="margin-top:12px;padding-top:12px;border-top:1px dashed var(--border)">
        <div style="font-size:12px;font-weight:700;color:var(--text2);margin-bottom:6px">🏭 Realistische Prognose (Prozessfähigkeits-DB)</div>
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:6px">
          <div style="font-family:'JetBrains Mono',monospace;font-size:20px;font-weight:700;color:${realCol}">Cpk ${realCpk.toFixed(2)}</div>
          <div style="font-size:12px;color:var(--text3)">${Math.round(realPpm).toLocaleString('de')} PPM${realDefectVeh!==null?` · ≈ ${realDefectVeh.toLocaleString('de')} Fzg`:''}</div>
        </div>
        <div style="font-size:11px;color:var(--text3);line-height:1.5">Gewichtet mit typischen Serien-Cpk je Verfahren (Schweißen 1.0, Tiefziehen/Guss 1.33, Spritzguss 1.5). Realistischer als der Idealfall, da reale Prozesse nicht perfekt zentriert/fähig sind.</div>
      </div>`:''}
    </div>`;
}

// ══ CP/CPK ════════════════════════════════════════════════════════
function calcCP(){
  const lsl=parseFloat(document.getElementById('lsl').value);
  const usl=parseFloat(document.getElementById('usl').value);
  const vals=parseVals('cp-values');
  if(vals.length<4||isNaN(lsl)||isNaN(usl)||usl<=lsl){toast('Bitte mindestens 4 Messwerte sowie gültige LSL/USL-Grenzen eingeben.','error');return;}
  const n=vals.length,mean=vals.reduce((a,v)=>a+v,0)/n;
  const s=Math.sqrt(vals.reduce((a,v)=>a+Math.pow(v-mean,2),0)/(n-1));
  const cp=(usl-lsl)/(6*s),cpl=(mean-lsl)/(3*s),cpu=(usl-mean)/(3*s),cpk=Math.min(cpl,cpu);
  const sigma=cpk*3,ppm=(normCDF(-(mean-lsl)/s)+normCDF(-(usl-mean)/s))*1e6;
  const color=capColor(cpk);
  const rating=cpk>=1.67?'Exzellent (Six Sigma)':cpk>=1.33?'Gut – Serienproduktion':cpk>=1.0?'Grenzwertig':'Kritisch!';
  const ppct=Math.min(Math.max(cpk/2*100,0),100);
  const r=document.getElementById('cp-result');
  r.className='';
  r.innerHTML=`
    <div class="card">
      <div class="card-title"><svg viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="currentColor"/></svg>Kennzahlen</div>
      <div class="row3" style="margin-bottom:10px">
        <div class="metric"><div class="metric-val" style="color:${color}">${fmt(cp,2)}</div><div class="metric-lbl">Cp</div></div>
        <div class="metric"><div class="metric-val" style="color:${color}">${fmt(cpk,2)}</div><div class="metric-lbl">Cpk</div></div>
        <div class="metric"><div class="metric-val" style="color:${color}">${fmt(sigma,1)}σ</div><div class="metric-lbl">Sigma</div></div>
      </div>
      <div class="banner" style="background:${color}18;color:${color};margin-bottom:12px">
