// ══ ISO HOLE/PIN DATEN (vereinfacht, 10mm Nenndurchmesser) ════════════
function calcISO(nom, holeCode, pinCode){
  // Grundabmaße nach ISO 286 (vereinfacht, gültig für 6–18mm Bereich)
  // Bohrungsabmaße (H-System: unteres Abmaß = 0)
  const IT_grades = {
    'IT6': 0.011, 'IT7': 0.018, 'IT8': 0.027, 'IT9': 0.043
  };
  // Hole fundamental deviations (EI = 0 for H)
  const holeData = {
    'H6': {EI:0, ES: 0.011},
    'H7': {EI:0, ES: 0.018},
    'H8': {EI:0, ES: 0.027},
    'H9': {EI:0, ES: 0.043},
  };
  // Shaft fundamental deviations (es = upper deviation)
  const shaftData = {
    'g6': {es:-0.005, ei:-0.016},
    'f7': {es:-0.013, ei:-0.031},
    'h6': {es:0,      ei:-0.011},
    'k6': {es:0.006,  ei:-0.005},
    'n6': {es:0.019,  ei:0.008},
    'p6': {es:0.026,  ei:0.015},
  };
  const h = holeData[holeCode];
  const s = shaftData[pinCode];
  if(!h||!s) return null;
  // Scale by nominal (approximate for 6-18mm range)
  const scale = nom / 10;
  const holeUpper = h.ES * scale;
  const holeLower = h.EI * scale;
  const shaftUpper = s.es * scale;
  const shaftLower = s.ei * scale;
  const maxClearance = holeUpper - shaftLower;
  const minClearance = holeLower - shaftUpper;
  const isInterference = minClearance < 0;
  return {holeUpper,holeLower,shaftUpper,shaftLower,maxClearance,minClearance,isInterference};
}

