function confirmLink(i){
  links[i].confirmed = !links[i].confirmed;
  renderLinks();
  const b=document.getElementById('lb-'+i);
  const e=document.getElementById('exp-'+i);
  if(b){b.classList.remove('hidden');if(e)e.style.transform='rotate(180deg)';}
}
// Loop-Richtung setzen (+1 vergrößert, −1 verkleinert das Schließmaß)
function setLinkDir(i, dir){
  links[i].dir = dir;
  renderLinks();
  const b=document.getElementById('lb-'+i);
  const e=document.getElementById('exp-'+i);
  if(b){b.classList.remove('hidden');if(e)e.style.transform='rotate(180deg)';}
}

function toggleLink(i){
  const b=document.getElementById('lb-'+i);
  const e=document.getElementById('exp-'+i);
  const hidden=b.classList.toggle('hidden');
  e.style.transform=hidden?'':'rotate(180deg)';
}
function syncLinkTol(i,side,val){
  const v=parseFloat(val)||0;
  if(side==='upper'){links[i].upper=v;links[i].lower=-Math.abs(v);}
  else{links[i].lower=v;links[i].upper=Math.abs(v);}
}
function syncLinkSym(i){
  const v=Math.max(Math.abs(links[i].upper),Math.abs(links[i].lower));
  links[i].upper=v;links[i].lower=-v;
  renderLinks();
}
function removeLink(i){links.splice(i,1);renderLinks();}

// ══ TOLERANZKETTE ═════════════════════════════════════════════════
// Spec-Bewertungskarte für Kette-Tab
function renderTCSpecCard(istTolRSS, istTolWC, rssSpanHalf){
  const s = chainSpec;
  const utilRSS = (istTolRSS / s.tol) * 100;
  const sigma = (rssSpanHalf * 2) / 6;
  const cpkEst = sigma > 0 ? s.tol / (3 * sigma) : 99;
  let color, text, icon;
  if(utilRSS <= 100 && cpkEst >= s.cpk){ color='#1DAA6A'; text='Vorgabe erfüllt'; icon='M5 12l5 5L19 7'; }
  else if(utilRSS <= 110 || cpkEst >= s.cpk*0.9){ color='#F5A623'; text='Grenzwertig'; icon='M12 9v4M12 17h.01'; }
  else { color='#D93025'; text='Vorgabe nicht erfüllt'; icon='M18 6L6 18M6 6l12 12'; }
  return `
    <div class="card" style="border:2px solid ${color};padding:0;overflow:hidden">
      <div style="background:${color};padding:10px 14px;display:flex;align-items:center;gap:10px">
        <svg viewBox="0 0 24 24" fill="none" style="width:20px;height:20px;stroke:#fff;stroke-width:2.4"><path d="${icon}" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <span style="color:#fff;font-weight:700;font-size:14px">${text}</span>
        <span style="margin-left:auto;color:#fff;font-size:12px;font-family:'JetBrains Mono',monospace;font-weight:600">${utilRSS.toFixed(0)}%</span>
      </div>
      <div style="padding:14px">
        <div class="stat-row"><span class="stat-lbl">Vorgabe (Soll)</span><span class="stat-val">${s.nom?fmt(s.nom,1)+'mm ':''}±${fmt(s.tol,1)} mm</span></div>
        <div class="stat-row"><span class="stat-lbl">Ist statistisch (${sigmaLabel()})</span><span class="stat-val" style="color:${utilRSS<=100?'#1DAA6A':'#D93025'}">${fmtSigma(istTolRSS)}</span></div>
        <div class="stat-row"><span class="stat-lbl">Cpk (Schätzung / Ziel)</span><span class="stat-val" style="color:${cpkEst>=s.cpk?'#1DAA6A':'#D93025'}">${fmt(cpkEst,2)} / ${fmt(s.cpk,2)}</span></div>
        <div class="stat-row"><span class="stat-lbl">Reserve</span><span class="stat-val" style="color:${s.tol-istTolRSS>=0?'#1DAA6A':'#D93025'}">${s.tol-istTolRSS>=0?'+':''}${fmt(s.tol-istTolRSS,3)} mm</span></div>
      </div>
    </div>`;
}

// ══ LOOP-DIAGRAMM (Schließmaß-Kette mit Richtungspfeilen) ══════════════
// Visualisiert die Toleranzkette als gerichteten Loop: jeder Beitragsleister
// zeigt mit +/− Pfeil, ob er das Schließmaß vergrößert oder verkleinert.
function renderLoopDiagram(){
  if(!links.length) return '';
  const nodes = links.map((l,i)=>{
    const dir = l.dir||1;
    const isMontage = l.type==='montage';
    const col = isMontage ? '#4BA3E3' : (mfgColors[l.type==='holepin'?'holepin':l.mfg]||'#8A93A2');
    const arrowCol = dir>0 ? '#1DAA6A' : '#D93025';
    const half = Math.max(l.upper,-l.lower);
    return { i, name:l.name, col, dir, arrowCol, half, isMontage };
  });
  const row = nodes.map((n,idx)=>{
    const arrow = dir=>dir>0
      ? `<svg viewBox="0 0 34 20" fill="none"><path d="M2 10h26M22 4l8 6-8 6" stroke="${n.arrowCol}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>`
      : `<svg viewBox="0 0 34 20" fill="none"><path d="M32 10H6M12 4l-8 6 8 6" stroke="${n.arrowCol}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>`;
    return `
      <div class="loop-node">
        <div class="loop-node-box" style="background:${n.col}">${n.i+1}</div>
        <div class="loop-node-lbl" title="${n.name}">${n.name.length>9?n.name.slice(0,8)+'…':n.name}</div>
      </div>
      ${idx<nodes.length-1?`<div class="loop-arrow">${arrow(nodes[idx+1].dir)}<span class="loop-arrow-lbl" style="color:${nodes[idx+1].arrowCol}">${nodes[idx+1].dir>0?'+':'−'}${fmt(nodes[idx+1].half,1)}</span></div>`:''}
    `;
  }).join('');
  // Start- und End-Marker (Schließmaß-Pfeile)
  return `
    <div class="card">
      <div class="card-title"><svg viewBox="0 0 24 24" fill="none"><circle cx="5" cy="12" r="2" fill="currentColor"/><circle cx="19" cy="12" r="2" fill="currentColor"/><path d="M7 12h10M14 9l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>Loop-Diagramm (Schließmaß-Kette)</div>
      <div style="font-size:13px;color:var(--text3);margin-bottom:10px;line-height:1.5">Geschlossene Kette von Bauteil A bis B. <span style="color:#1DAA6A;font-weight:600">Grün ＋</span> = vergrößert, <span style="color:#D93025;font-weight:600">Rot －</span> = verkleinert das Schließmaß. Richtung pro Glied im Detail einstellbar.</div>
      <div class="loop-diagram">
        <div class="loop-row">
          <div class="loop-node">
            <div class="loop-node-box" style="background:#0f2447">A</div>
            <div class="loop-node-lbl">Start</div>
          </div>
          <div class="loop-arrow"><svg viewBox="0 0 34 20" fill="none"><path d="M2 10h26M22 4l8 6-8 6" stroke="var(--text3)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
          ${row}
          <div class="loop-arrow"><svg viewBox="0 0 34 20" fill="none"><path d="M2 10h26M22 4l8 6-8 6" stroke="var(--text3)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
          <div class="loop-node">
            <div class="loop-node-box" style="background:#0f2447">B</div>
            <div class="loop-node-lbl">Ziel</div>
          </div>
        </div>
      </div>
      <div style="font-size:11px;color:var(--text3);margin-top:8px;line-height:1.5">📐 Loop-Diagramm nach ASME Y14.5 / Drake: Pfeilrichtung bestimmt das Vorzeichen im Nennmaß. Die Toleranz-Spanne (RSS/WC) ist richtungsunabhängig.</div>
    </div>`;
}

function calcTC(){
  if(!links.length){toast('Bitte zuerst Beitragsleister hinzufügen.','error');return;}
  // Nennmaß mit Loop-Richtung (+1 vergrößert, −1 verkleinert das Schließmaß)
  const nom=links.reduce((a,l)=>a+l.nom*(l.dir||1),0);
  const wcU=links.reduce((a,l)=>a+l.upper,0);
  const wcL=links.reduce((a,l)=>a+l.lower,0);
  const midSum=links.reduce((a,l)=>a+((l.upper+l.lower)/2)*(l.dir||1),0);
  // RSS mit Verteilungsfaktor (Passungen = 1/√3)
  const rss=Math.sqrt(links.reduce((a,l)=>{
    const df=l.distributionFactor||1;
    return a+Math.pow((l.upper-l.lower)/2*df,2);
  },0));
  const rssU=midSum+rss,rssL=midSum-rss,wcR=wcU-wcL,rssR=rss*2;
  const pct=wcR>0?((rssR/wcR)*100).toFixed(1):0;
  const totalVar=links.reduce((a,l)=>a+Math.pow((l.upper-l.lower)/2,2),0);
  const contributors=links.map(l=>({
    name:l.name,pct:totalVar>0?(Math.pow((l.upper-l.lower)/2,2)/totalVar*100):0
  })).sort((a,b)=>b.pct-a.pct);

  // ══ HLM-Sensitivität (3DCS-inspiriert): Wenn Beitragsleister i halbiert wird, wie stark sinkt RSS? ══
  const sensitivity=links.map((l,i)=>{
    const halfTol=(l.upper-l.lower)/2;
    const df=l.distributionFactor||1;
    // RSS ohne diesen Beitragsleister, dann mit halbierter Toleranz
    const varWithout=links.reduce((a,ll,j)=>j===i?a:a+Math.pow((ll.upper-ll.lower)/2*(ll.distributionFactor||1),2),0);
    const rssHalved=Math.sqrt(varWithout+Math.pow(halfTol/2*df,2))*2;
    const improvement=rssR>0?((rssR-rssHalved)/rssR*100):0;
    return {name:l.name, improvement, newRss:rssHalved};
  }).sort((a,b)=>b.improvement-a.improvement);
  const maxImprove=Math.max(...sensitivity.map(s=>s.improvement),0.01);

  const r=document.getElementById('tc-result');
  r.className='';
  r.innerHTML=`
    ${chainSpec ? renderTCSpecCard(rssR/2, wcR/2, rss) : ''}
    <div class="card">
      <div class="card-title"><svg viewBox="0 0 24 24" fill="none"><path d="M12 20V4M4 12h16" stroke="currentColor" stroke-linecap="round"/></svg>Nennmaß gesamt</div>
      <div style="font-size:clamp(22px,6vw,28px);font-weight:700;font-family:'JetBrains Mono',monospace;color:var(--blue)">${fmt(nom,3)} <span style="font-size:14px;color:var(--text3);font-weight:400">mm</span></div>
      <div style="font-size:12px;color:var(--text3);margin-top:4px">Mit Loop-Richtung: ＋ vergrößert, － verkleinert das Schließmaß</div>
    </div>
    ${renderLoopDiagram()}
    <div class="card">
      <div class="card-title"><svg viewBox="0 0 24 24" fill="none"><rect x="3" y="14" width="3" height="7" rx="1" fill="currentColor" opacity=".4"/><rect x="8" y="9" width="3" height="12" rx="1" fill="currentColor"/><rect x="13" y="5" width="3" height="16" rx="1" fill="currentColor" opacity=".7"/></svg>Methoden-Vergleich</div>
      <div class="comp-row">
        <div class="comp-label"><span><span class="comp-dot" style="background:#D93025"></span>Worst-Case</span><span style="font-family:'JetBrains Mono',monospace;font-size:12px">+${fmt(wcU,3)} / ${fmt(wcL,3)}</span></div>
        <div class="progress-bg"><div class="progress-fill" style="width:100%;background:#D93025"></div></div>
        <div style="font-size:13px;color:var(--text3);margin-top:3px">Spanne ${fmt(wcR,3)} mm</div>
      </div>
      <div class="comp-row" style="margin-top:10px">
        <div class="comp-label"><span><span class="comp-dot" style="background:#1DAA6A"></span>RSS statistisch</span><span style="font-family:'JetBrains Mono',monospace;font-size:12px">${fmtSigma(rss)}</span></div>
        <div class="progress-bg"><div class="progress-fill" style="width:${pct}%;background:#1DAA6A"></div></div>
        <div style="font-size:13px;color:var(--text3);margin-top:3px">±x bei ${sigmaLabel()} · Mitte ${fmt(midSum,3)} · ${pct}% von WC</div>
      </div>
    </div>
    <div class="card lvl-explain" style="background:var(--surface2)">
      <div style="font-size:13px;color:var(--text2);line-height:1.6">
        <strong>📐 Ergebnisformat:</strong> Die statistische Schließmaßtoleranz wird als <strong>±x bei ${sigmaMode}σ</strong> angegeben${sigmaMode===4?' (konservativ, Cpk≈1.33)':' (99.73%)'}, mit dem jeweils anderen Wert in Klammern. Umschaltbar oben im Tab.
      </div>
    </div>
    <div class="card">
      <div class="card-title"><svg viewBox="0 0 24 24" fill="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 21 12 17.77 5.82 21 7 14.14l-5-4.87 6.91-1.01L12 2z" fill="currentColor" opacity=".8"/></svg>Beitragsanalyse</div>
      ${contributors.map(c=>`
        <div class="contrib-row">
          <div style="min-width:90px;font-size:12px;color:var(--text2);font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${c.name}</div>
          <div class="contrib-bar-bg"><div class="contrib-bar-fill" style="width:${c.pct.toFixed(1)}%;background:${c.pct>40?'#D93025':c.pct>20?'#F5A623':'#1A6FD4'}"></div></div>
          <div class="contrib-pct" style="color:${c.pct>40?'#D93025':c.pct>20?'#F5A623':'var(--text2)'}">${c.pct.toFixed(1)}%</div>
        </div>`).join('')}
    </div>
    <div class="card">
      <div class="card-title"><svg viewBox="0 0 24 24" fill="none"><path d="M3 3v18h18M7 14l4-4 4 4 5-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>Sensitivität (HLM)</div>
      <div style="font-size:13px;color:var(--text3);margin-bottom:10px;line-height:1.5">Wenn ein Beitragsleister halbiert wird – wie stark sinkt die Gesamttoleranz (RSS 4σ)? Größter Hebel zuerst.</div>
      ${sensitivity.map(sv=>`
        <div class="contrib-row">
          <div style="min-width:90px;font-size:12px;color:var(--text2);font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${sv.name}</div>
          <div class="contrib-bar-bg"><div class="contrib-bar-fill" style="width:${(sv.improvement/maxImprove*100).toFixed(1)}%;background:${sv.improvement>15?'#1DAA6A':sv.improvement>7?'#F5A623':'#8A93A2'}"></div></div>
          <div class="contrib-pct" style="color:${sv.improvement>15?'#1DAA6A':sv.improvement>7?'#F5A623':'var(--text3)'}">−${sv.improvement.toFixed(1)}%</div>
        </div>`).join('')}
      <div style="font-size:12px;color:var(--text3);margin-top:8px">−% = Reduktion der Gesamttoleranz bei Halbierung dieses Beitragsleisters</div>
    </div>
    ${chainSpec ? renderAllocationCard(rss) : ''}
    ${renderYieldCard(rss)}
