// ── iOS-Walzen-Picker (Multi-Instanz: spec/cfg/mont) ──
// Werte 0.1 … 5.0 in 0.1-Schritten (1 Nachkommastelle)
const WHEEL_STEP=0.1, WHEEL_MIN=0.1, WHEEL_MAX=5.0, WHEEL_ITEM_H=40, WHEEL_H=120;
const WHEEL_VALUES=(()=>{const a=[];for(let v=WHEEL_MIN;v<=WHEEL_MAX+1e-9;v+=WHEEL_STEP)a.push(Math.round(v*10)/10);return a;})();
// Registry je Walzen-Instanz: { idx, onChange(value), prefix() }
const _wheels = {};
let _wheelIdx = 4; // Rückwärtskompatibel für spec (Default 0.5)

function _wheelReg(key, opts){ _wheels[key] = Object.assign({idx:4, prefix:()=>'±', onChange:null}, opts); }
function buildWheelInstance(key){
  const track=document.getElementById(key+'-wheel-track');
  if(!track) return;
  const w=_wheels[key]||(_wheels[key]={idx:4,prefix:()=>'±',onChange:null});
  const padCount=Math.floor(WHEEL_H/WHEEL_ITEM_H/2)+1;
  let h='';
  for(let i=0;i<padCount;i++) h+='<div class="wheel-item">&nbsp;</div>';
  WHEEL_VALUES.forEach((v,i)=>{ h+=`<div class="wheel-item" data-idx="${i}">${w.prefix()}${v.toFixed(1)}</div>`; });
  for(let i=0;i<padCount;i++) h+='<div class="wheel-item">&nbsp;</div>';
  track.innerHTML=h;
  track._pad=padCount;
  w.built=true;
  setWheelIndexInstance(key, w.idx, false);
}
function _wheelOffsetForIdx(key, idx){
  const track=document.getElementById(key+'-wheel-track');
  const pad=track?track._pad:2;
  return WHEEL_H/2 - (pad+idx)*WHEEL_ITEM_H - WHEEL_ITEM_H/2;
}
function setWheelIndexInstance(key, idx, fire=true){
  idx=Math.max(0,Math.min(WHEEL_VALUES.length-1,idx));
  const w=_wheels[key]; if(!w) return;
  w.idx=idx;
  if(key==='spec') _wheelIdx=idx; // Rückwärtskompatibilität
  const track=document.getElementById(key+'-wheel-track'); if(!track) return;
  track.style.transform=`translateY(${_wheelOffsetForIdx(key,idx)}px)`;
  track.querySelectorAll('.wheel-item').forEach(el=>{
    el.classList.toggle('sel', el.dataset.idx!==undefined && +el.dataset.idx===idx);
  });
  const v=WHEEL_VALUES[idx];
  const lbl=document.getElementById(key+'-wheel-val'); if(lbl) lbl.textContent=w.prefix()+v.toFixed(1);
  if(fire && typeof w.onChange==='function') w.onChange(v);
}
function updateWheelInstance(key, v){
  const w=_wheels[key]; if(!w) return;
  if(!w.built) buildWheelInstance(key);
  const lbl=document.getElementById(key+'-wheel-val');
  if(!v||isNaN(v)){ if(lbl)lbl.textContent=w.prefix()+'–'; return; }
  let idx=Math.round((v-WHEEL_MIN)/WHEEL_STEP);
  idx=Math.max(0,Math.min(WHEEL_VALUES.length-1,idx));
  setWheelIndexInstance(key, idx, false);
  if(lbl) lbl.textContent=w.prefix()+(Math.round(v*10)/10).toFixed(1);
}
// Touch/Drag-Steuerung (instanzbasiert über data-wheel-key)
let _wDrag=null,_wStartY=0,_wStartOffset=0;
function _wheelCurrentOffset(key){
  const track=document.getElementById(key+'-wheel-track');
  const m=/translateY\((-?[\d.]+)px\)/.exec(track.style.transform||'');
  return m?parseFloat(m[1]):_wheelOffsetForIdx(key,_wheels[key]?_wheels[key].idx:4);
}
function _wheelStart(key,y){ _wDrag=key; _wStartY=y; _wStartOffset=_wheelCurrentOffset(key); const t=document.getElementById(key+'-wheel-track'); if(t)t.style.transition='none'; }
function _wheelMove(y){
  if(!_wDrag) return;
  const track=document.getElementById(_wDrag+'-wheel-track');
  track.style.transform=`translateY(${_wStartOffset+(y-_wStartY)}px)`;
}
function _wheelEnd(){
  if(!_wDrag) return; const key=_wDrag; _wDrag=null;
  const track=document.getElementById(key+'-wheel-track');
  const pad=track._pad;
  const off=_wheelCurrentOffset(key);
  let idx=Math.round((WHEEL_H/2 - off - WHEEL_ITEM_H/2)/WHEEL_ITEM_H - pad);
  track.style.transition='transform .2s cubic-bezier(.22,.61,.36,1)';
  setWheelIndexInstance(key, idx, true);
}
// Generische Event-Handler – key kommt aus data-wheel-key des Tracks
function wheelTouchKey(e,phase){
  e.preventDefault();
  const key=e.currentTarget.getAttribute('data-wheel-key');
  if(phase==='start')_wheelStart(key, e.touches[0].clientY);
  else if(phase==='move')_wheelMove(e.touches[0].clientY);
  else _wheelEnd();
}
function wheelMouseKey(e,phase){
  const key=e.currentTarget.getAttribute('data-wheel-key');
  if(phase==='down')_wheelStart(key, e.clientY);
  else if(phase==='move')_wheelMove(e.clientY);
  else _wheelEnd();
}

