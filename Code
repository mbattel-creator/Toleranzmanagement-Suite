  }
  const prompt = `Du bist Experte für Fahrzeug-Toleranzketten in der Automobilindustrie (Funktionsmaßkonzept FMK).

Aufgabe: Baue eine realistische Toleranzkette für das Schließmaß zwischen "${partA}" und "${partB}" auf.
${context ? `Kontext: ${context}` : ''}${topoHint}

Antworte NUR mit einem JSON-Array ohne jeglichen Text davor oder danach, keine Markdown-Backticks, kein Kommentar:
[{"name":"Bauteilname","process":"Fertigungsverfahren","mfg":"stamping","nom":0,"upper":0.5,"lower":-0.5,"type":"bauteil","reason":"Begründung"}]

mfg-Werte: stamping, injection, welding, casting, glass, thermoform, extrusion, assembly, custom
type-Werte: bauteil, montage

Regeln:
- Beginne mit "${partA}" (Eigentoleranz)
- Füge ALLE realen Zwischenbauteile aus der Topologie ein (Karosserie-Bezüge, Klappen, Seitenwände) + Montagetoleranzen an jeder Schnittstelle
- Ende mit "${partB}" (Eigentoleranz)
- Toleranzen nach Fertigungsverfahren, nom=0, upper=-lower`;

  try {
    const response = await callClaude(prompt);
    let jsonStr = response.split('```').join('').trim();
    const start = jsonStr.indexOf('[');
    const end = jsonStr.lastIndexOf(']');
    if(start === -1 || end === -1) throw new Error('JSON nicht gefunden');
    jsonStr = jsonStr.slice(start, end+1);
    aiBuiltLinks = JSON.parse(jsonStr);
    if(!Array.isArray(aiBuiltLinks) || !aiBuiltLinks.length) throw new Error('Leeres Array');
    renderBuilderPreview(partA, partB, aiBuiltLinks, false);
  } catch(e) {
    // Fallback: Topologie zuerst, dann Vorlage
    let chain = buildChainFromTopology(partA, partB);
    let isGeneric = false;
    if(!chain){
      const tmpl = findLocalTemplate(partA, partB);
      if(tmpl){ chain = applyNamesToTemplate(tmpl, partA, partB); }
      else { chain = applyNamesToTemplate(CHAIN_TEMPLATES['default'], partA, partB); isGeneric = true; }
