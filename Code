      <button onclick="removeParetoRow(${i})" style="width:30px;height:30px;border-radius:6px;border:1px solid var(--border);background:var(--surface);cursor:pointer;font-size:14px;flex-shrink:0">🗑️</button>
    </div>`).join('');
}
function addParetoRow(){ paretoRows.push({cause:'',count:''}); renderParetoInputs(); }
function removeParetoRow(i){ if(paretoRows.length>1){paretoRows.splice(i,1); renderParetoInputs();} }

function calcPareto(){
  const data = paretoRows
    .map(r=>({cause:r.cause.trim()||'(unbenannt)', count:parseFloat(r.count)||0}))
    .filter(r=>r.count>0)
    .sort((a,b)=>b.count-a.count);
  if(!data.length){ toast('Bitte mindestens eine Ursache mit Anzahl > 0 eingeben.','error'); return; }

  const total = data.reduce((a,r)=>a+r.count,0);
  let cum = 0;
  const rows = data.map(r=>{ cum+=r.count; return {...r, pct:r.count/total*100, cumPct:cum/total*100}; });
  const maxC = data[0].count;
  // "Vital few": Ursachen bis 80% kumuliert
  const vitalCount = rows.findIndex(r=>r.cumPct>=80)+1;

  document.getElementById('pareto-result').className='';
  document.getElementById('pareto-result').innerHTML = `
    <div class="card">
      <div class="card-title"><svg viewBox="0 0 24 24" fill="none"><path d="M3 3v18h18M7 14l4-4 4 4 5-6" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/></svg>Pareto-Diagramm</div>
      <div style="display:flex;align-items:flex-end;gap:4px;height:140px;border-bottom:2px solid var(--border);border-left:2px solid var(--border);padding:0 4px;position:relative">
        ${rows.map((r,i)=>{
          const isVital = i < vitalCount;
          return `<div style="flex:1;display:flex;flex-direction:column;align-items:center;justify-content:flex-end;height:100%;position:relative">
            <div style="font-size:11px;color:var(--text3);margin-bottom:2px">${r.count}</div>
            <div style="width:100%;max-width:38px;height:${Math.round(r.count/maxC*100)}%;background:${isVital?'#D93025':'#1A6FD4'};border-radius:4px 4px 0 0;min-height:4px"></div>
          </div>`;
        }).join('')}
        <!-- Kumulative Linie als Punkte -->
        <div style="position:absolute;left:0;right:0;top:0;bottom:0;pointer-events:none">
          ${rows.map((r,i)=>{
            const x = ((i+0.5)/rows.length*100);
            const y = (100 - r.cumPct);
            return `<div style="position:absolute;left:${x}%;top:${y}%;width:7px;height:7px;background:#1DAA6A;border:2px solid #fff;border-radius:50%;transform:translate(-50%,-50%);box-shadow:0 0 0 1px #1DAA6A"></div>`;
          }).join('')}
        </div>
        <!-- 80%-Linie -->
        <div style="position:absolute;left:0;right:0;top:20%;border-top:1px dashed #F5A623"><span style="position:absolute;right:2px;top:-14px;font-size:11px;color:#F5A623;font-weight:700">80%</span></div>
      </div>
      <div style="display:flex;gap:4px;margin-top:6px">
        ${rows.map(r=>`<div style="flex:1;font-size:11px;color:var(--text3);text-align:center;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${r.cause}</div>`).join('')}
      </div>
      <div style="background:#D9302510;border:1px solid #D9302540;border-radius:8px;padding:10px 12px;margin-top:14px">
        <div style="font-size:12px;font-weight:600;color:#D93025">🎯 Vital Few (80%-Regel)</div>
        <div style="font-size:12px;color:var(--text2);margin-top:4px;line-height:1.5">Die ersten <strong>${vitalCount}</strong> von ${rows.length} Ursachen verursachen ${rows[vitalCount-1].cumPct.toFixed(0)}% aller Fehler. Hier zuerst ansetzen.</div>
      </div>
      <div style="margin-top:12px">
        ${rows.map((r,i)=>`<div class="stat-row"><span class="stat-lbl">${i<vitalCount?'🔴':'🔵'} ${r.cause}</span><span class="stat-val">${r.count} · ${r.pct.toFixed(1)}% · Σ${r.cumPct.toFixed(0)}%</span></div>`).join('')}
      </div>
    </div>`;
}

