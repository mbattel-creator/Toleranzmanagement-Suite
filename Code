<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Toleranzmanagement Tool v0.1.0-alpha</title>
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="Toleranz">
<meta name="mobile-web-app-capable" content="yes">
<meta name="theme-color" content="#0f2447">
<meta name="format-detection" content="telephone=no">
<link rel="apple-touch-icon" href="data:image/png;base64,">
<link rel="icon" type="image/png" href="data:image/png;base64,">
<link rel="manifest" href="data:application/json;base64,">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root{
  --blue:#1A6FD4;--blue-light:#EBF3FF;--blue-mid:#4A90D9;
  --green:#1DAA6A;--yellow:#F5A623;--red:#D93025;
  --bg:#F0F2F5;--surface:#fff;--surface2:#F7F9FC;
  --border:#E2E6EC;--border2:#D0D5DE;
  --text:#0D1117;--text2:#5A6272;--text3:#8A93A2;
  --radius:12px;--radius-sm:8px;--radius-lg:16px;
  --shadow:0 1px 4px rgba(0,0,0,.08),0 4px 16px rgba(0,0,0,.04);
  /* Proportionierte Schrift-Skala (Modular Scale ~1.18×, mobil-optimiert) */
  --fs-xs:12px;    /* Mikro-Labels, Hinweise */
  --fs-sm:14px;    /* Sekundärtext, Captions */
  --fs-base:16px;  /* Standard: Inputs, Fließtext, Buttons */
  --fs-md:18px;    /* Hervorhebung, Karten-Titel */
  --fs-lg:22px;    /* Werte, Slider-Wert */
  --fs-xl:27px;    /* Große Metriken */
  --fs-2xl:32px;   /* Hauptmetriken */
  /* Feld-Innenabstand: exakt 5px vertikal damit Text das Feld füllt */
  --field-pad-y:5px;
  --field-pad-x:10px;
}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
html,body{font-family:'Inter',sans-serif;background:var(--bg);color:var(--text);font-size:var(--fs-base)}
.app{max-width:480px;margin:0 auto;min-height:100vh;display:flex;flex-direction:column}

.header{background:linear-gradient(135deg,#0a1628 0%,#0f2447 40%,#1A6FD4 100%);padding:clamp(14px,4vw,20px) clamp(14px,4vw,20px) clamp(12px,3vw,16px);position:relative;overflow:hidden;display:flex;align-items:flex-start;justify-content:space-between}
.header-gear{background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.2);border-radius:10px;width:38px;height:38px;display:flex;align-items:center;justify-content:center;cursor:pointer;flex-shrink:0;color:#fff;transition:background .2s;z-index:2}
.header-gear:hover{background:rgba(255,255,255,.22)}
.header-gear svg{width:20px;height:20px}
#key-panel{background:var(--surface);border-bottom:1px solid var(--border);padding:14px clamp(14px,4vw,20px);animation:slideDown .25s ease}
@keyframes slideDown{from{opacity:0;transform:translateY(-8px)}to{opacity:1;transform:translateY(0)}}
.key-panel-inner{max-width:480px;margin:0 auto}
.header::before{content:'';position:absolute;top:-40px;right:-40px;width:160px;height:160px;border-radius:50%;background:rgba(255,255,255,.04)}
.brand{position:relative;z-index:1}
.brand-name{font-size:clamp(10px,2.5vw,12px);font-weight:600;color:rgba(255,255,255,.5);letter-spacing:2px;text-transform:uppercase;margin-bottom:4px}
.brand-title{font-size:clamp(16px,5vw,22px);font-weight:700;color:#fff;letter-spacing:-0.5px}
.brand-title span{color:#7ee8fa}
.brand-badge{display:inline-flex;align-items:center;gap:5px;margin-top:6px;background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.15);border-radius:20px;padding:3px 10px;font-size:12px;font-weight:500;color:rgba(255,255,255,.7);letter-spacing:.5px}
.brand-author{font-size:clamp(11px,2.8vw,13px);font-weight:500;color:#7ee8fa;margin-top:3px;letter-spacing:.3px;font-style:italic}
.header-actions{display:flex;gap:8px;flex-shrink:0;z-index:2}
.sigma-btn{background:var(--surface2);border:1px solid var(--border);border-radius:7px;padding:4px 12px;font-size:12px;font-weight:600;font-family:'JetBrains Mono',monospace;color:var(--text3);cursor:pointer;transition:all .15s}
.sigma-btn.active{background:var(--blue);border-color:var(--blue);color:#fff}
.lang-btn{background:var(--surface2);border:1px solid var(--border);border-radius:7px;padding:4px 12px;font-size:12px;font-weight:700;color:var(--text3);cursor:pointer;transition:all .15s}
.lang-btn.active{background:var(--blue);border-color:var(--blue);color:#fff}
.info-btn{width:22px;height:22px;border-radius:50%;border:1.5px solid var(--blue);background:var(--surface);color:var(--blue);font-size:12px;font-weight:700;font-style:italic;font-family:Georgia,serif;cursor:pointer;flex-shrink:0;display:flex;align-items:center;justify-content:center;line-height:1;padding:0}
.info-btn:hover{background:var(--blue);color:#fff}
.info-box{background:var(--blue-light);border:1px solid rgba(26,111,212,.2);border-radius:8px;padding:10px 12px;font-size:var(--fs-xs);color:var(--text2);line-height:1.55;margin-bottom:12px}
.veh-thumb{display:flex;align-items:center;justify-content:center;width:46px;height:32px;padding:3px;background:var(--surface);border:1px solid var(--border);border-radius:6px;cursor:pointer;transition:all .15s}
.veh-thumb:hover{border-color:var(--blue)}
.veh-thumb.active{border-color:var(--blue);background:var(--blue-light)}
.veh-thumb svg{opacity:.7}
.veh-thumb:hover svg,.veh-thumb.active svg{opacity:1}
.part-suggest{position:absolute;top:100%;left:0;right:0;z-index:50;background:var(--surface);border:1px solid var(--border);border-radius:8px;box-shadow:0 6px 20px rgba(0,0,0,.12);max-height:240px;overflow-y:auto;margin-top:3px}
.part-suggest-item{padding:8px 10px;font-size:var(--fs-sm);cursor:pointer;border-bottom:1px solid var(--border);display:flex;flex-direction:column;gap:1px}
.part-suggest-item:last-child{border-bottom:none}
.part-suggest-item:hover,.part-suggest-item.active{background:var(--blue-light)}
.part-suggest-item .ps-name{color:var(--text);font-weight:500}
.part-suggest-item .ps-cat{font-size:12px;color:var(--text3)}
.part-suggest-item .ps-hint{font-size:12px;color:var(--blue)}
.part-suggest-empty{padding:10px;font-size:12px;color:var(--text3);text-align:center}
.req-class-btn{flex:1;padding:7px 4px;font-size:13px;font-weight:600;border:1px solid var(--border);border-radius:7px;background:var(--surface);color:var(--text3);cursor:pointer;transition:all .15s;font-family:'Inter',sans-serif}
.req-class-btn.active{border-color:var(--blue);background:var(--blue-light);color:var(--blue)}
.req-class-btn[data-class="functional"].active{border-color:#1DAA6A;background:rgba(29,170,106,.1);color:#1DAA6A}
.req-class-btn[data-class="safety"].active{border-color:#D93025;background:rgba(217,48,37,.1);color:#D93025}
.ulevel-btn{flex:1;padding:7px 4px;font-size:13px;font-weight:600;border:1px solid var(--border);border-radius:7px;background:var(--surface);color:var(--text3);cursor:pointer;transition:all .15s;font-family:'Inter',sans-serif}
.ulevel-btn.active{border-color:var(--blue);background:var(--blue);color:#fff}
.feat-btn{flex:1;padding:8px 4px;font-size:13px;font-weight:600;border:1px solid var(--border);border-radius:7px;background:var(--surface);color:var(--text3);cursor:pointer;transition:all .15s;font-family:'Inter',sans-serif}
.feat-btn.active{border-color:var(--blue);background:var(--blue-light);color:var(--blue)}
.eval-btn{padding:6px 11px;font-size:12px;font-weight:600;border:1px solid var(--border);border-radius:7px;background:var(--surface);color:var(--text3);cursor:pointer;transition:all .15s;font-family:'Inter',sans-serif}
.eval-btn.active{border-color:var(--green);background:rgba(29,170,106,.1);color:var(--green)}
.disabled-alpha{opacity:.45;cursor:not-allowed!important;position:relative}
.disabled-alpha:active{transform:none!important}
/* Info-Tooltip (i) */
.info-i{display:inline-flex;align-items:center;justify-content:center;width:18px;height:18px;min-width:18px;border-radius:50%;border:1.5px solid var(--blue);color:var(--blue);background:var(--surface);font-size:11px;font-weight:700;font-style:italic;font-family:Georgia,serif;cursor:pointer;line-height:1;vertical-align:middle;margin-left:5px;flex-shrink:0;-webkit-tap-highlight-color:transparent}
.info-i:active{background:var(--blue);color:#fff}
.info-pop-bg{position:fixed;inset:0;background:rgba(0,0,0,.4);z-index:2000;display:flex;align-items:center;justify-content:center;padding:24px;animation:fadeIn .15s}
.info-pop{background:var(--surface);border-radius:14px;padding:18px 20px;max-width:340px;box-shadow:0 8px 32px rgba(0,0,0,.25);animation:popIn .2s}
.info-pop-title{font-size:15px;font-weight:700;color:var(--text);margin-bottom:8px;display:flex;align-items:center;gap:7px}
.info-pop-body{font-size:14px;color:var(--text2);line-height:1.6}
.info-pop-close{margin-top:14px;width:100%;padding:10px;border:none;border-radius:8px;background:var(--blue);color:#fff;font-size:14px;font-weight:600;cursor:pointer;font-family:'Inter',sans-serif}
@keyframes popIn{from{transform:scale(.92);opacity:0}to{transform:scale(1);opacity:1}}
/* iOS-Walzen-Picker */
.wheel-wrap{background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius-sm);padding:12px}
.wheel-val{font-family:'JetBrains Mono',monospace;font-size:22px;font-weight:700;color:var(--blue);letter-spacing:-0.5px}
.wheel-picker{position:relative;height:120px;overflow:hidden;border-radius:10px;background:linear-gradient(var(--surface),var(--surface2) 50%,var(--surface));-webkit-mask-image:linear-gradient(transparent,#000 22%,#000 78%,transparent);mask-image:linear-gradient(transparent,#000 22%,#000 78%,transparent)}
.wheel-track{position:absolute;left:0;right:0;top:0;touch-action:none;-webkit-user-select:none;user-select:none;cursor:grab}
.wheel-track:active{cursor:grabbing}
.wheel-item{height:40px;display:flex;align-items:center;justify-content:center;font-family:'JetBrains Mono',monospace;font-size:18px;font-weight:600;color:var(--text3);transition:color .12s,transform .12s,opacity .12s}
.wheel-item.sel{color:var(--blue);font-size:22px;font-weight:700}
.wheel-center-line{position:absolute;left:8px;right:8px;top:50%;height:40px;transform:translateY(-50%);border-top:1.5px solid var(--blue);border-bottom:1.5px solid var(--blue);opacity:.35;pointer-events:none;border-radius:6px}
/* App-weite Detailtiefe nach Anwenderlevel */
.lvl-explain{display:block}
.lvl-detail{display:block}
html[data-level="audit"] .lvl-explain{display:none !important}
html[data-level="audit"] .lvl-detail{display:none !important}
html[data-level="specialist"] .lvl-detail{display:none !important}
html[data-level="expert"] .lvl-detail{display:block}
.brand-badge::before{content:'';width:6px;height:6px;border-radius:50%;background:#2dd4bf;animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}

.tab-bar{display:flex;background:var(--surface);border-bottom:1px solid var(--border);position:sticky;top:0;z-index:100;box-shadow:var(--shadow)}
.tab{flex:1;padding:10px 2px 8px;text-align:center;cursor:pointer;border:none;background:none;color:var(--text3);font-size:clamp(10px,2.6vw,12px);font-family:'Inter',sans-serif;border-bottom:2px solid transparent;display:flex;flex-direction:column;align-items:center;gap:3px;transition:color .2s}
.tab svg{width:20px;height:20px}
.tab.active{color:var(--blue);border-bottom-color:var(--blue)}

.screen{display:none;flex:1;padding:clamp(12px,3vw,16px);gap:clamp(10px,2.5vw,12px);flex-direction:column}
.screen.active{display:flex}

.card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:clamp(14px,3.5vw,16px);box-shadow:var(--shadow)}
.card-title{font-size:var(--fs-md);font-weight:700;color:var(--text2);margin-bottom:clamp(10px,2.5vw,12px);display:flex;align-items:center;gap:7px}
.card-title svg{width:16px;height:16px;stroke:var(--blue);stroke-width:2;flex-shrink:0}

.field-label{font-size:var(--fs-xs);font-weight:700;color:var(--text3);margin-bottom:5px;letter-spacing:.5px;text-transform:uppercase}
/* Confirm indicator per link */
.btn-confirm{display:flex;align-items:center;gap:6px;padding:8px 14px;border:1.5px solid #1DAA6A;border-radius:8px;background:rgba(29,170,106,.07);color:#1DAA6A;font-size:12px;font-weight:600;cursor:pointer;-webkit-tap-highlight-color:transparent;touch-action:manipulation;font-family:'Inter',sans-serif}
.btn-confirm.done{background:#1DAA6A;color:#fff}
.biw-opt{display:flex;gap:8px;align-items:flex-start;padding:8px 10px;border:1px solid var(--border);border-radius:8px;cursor:pointer;font-size:13px;color:var(--text2);line-height:1.4;transition:all .12s}
.biw-opt.active{border-color:var(--blue);background:var(--blue-light)}
.biw-opt input{margin-top:2px;accent-color:var(--blue);width:auto}
input[type=text],input[type=number],textarea,select{width:100%;background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius-sm);padding:var(--field-pad-y) var(--field-pad-x);font-size:var(--fs-base);line-height:1.25;font-family:'JetBrains Mono','Courier New',monospace;color:var(--text);outline:none;transition:border-color .2s,box-shadow .2s;-webkit-appearance:none}
input:focus,textarea:focus,select:focus{border-color:var(--blue);box-shadow:0 0 0 3px rgba(26,111,212,.12)}
select{font-family:'Inter',sans-serif;cursor:pointer}
textarea{min-height:80px;resize:vertical;font-family:'Inter',sans-serif;font-size:clamp(12px,3vw,13px)}
input[type=range]{width:100%;accent-color:var(--blue);margin:6px 0}

.btn{width:100%;padding:clamp(14px,3.5vw,16px);background:var(--blue);color:#fff;border:none;border-radius:var(--radius-sm);font-size:clamp(14px,3.8vw,15px);font-weight:600;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;font-family:'Inter',sans-serif;transition:all .2s}
.btn:active{transform:scale(.98)}
.btn svg{width:16px;height:16px;stroke:#fff;stroke-width:2.2;flex-shrink:0}
.btn.secondary{background:none;color:var(--blue);border:1.5px solid var(--blue)}
.btn.secondary svg{stroke:var(--blue)}
.btn.ghost{background:var(--surface2);color:var(--text);border:1px solid var(--border)}
.btn.ghost svg{stroke:var(--text2)}
.btn.danger{background:var(--red)}
.btn.success{background:var(--green)}
.btn.sm{padding:8px 12px;font-size:12px;width:auto}

.row2{display:grid;grid-template-columns:1fr 1fr;gap:clamp(8px,2vw,10px)}
.row3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px}

.metric{background:var(--surface2);border-radius:var(--radius-sm);padding:clamp(10px,2.5vw,13px);text-align:center;border:1px solid var(--border)}
.metric-val{font-size:var(--fs-xl);font-weight:700;font-family:'JetBrains Mono',monospace;line-height:1.1}
.metric-lbl{font-size:clamp(9px,2.2vw,10px);color:var(--text3);margin-top:3px;letter-spacing:.5px;text-transform:uppercase;font-weight:500}

.stat-row{display:flex;justify-content:space-between;align-items:center;padding:clamp(8px,2vw,10px) 0;border-bottom:1px solid var(--border);font-size:clamp(12px,3.2vw,14px)}
.stat-row:last-child{border:none}
.stat-lbl{color:var(--text2)}
.stat-val{font-weight:600;font-family:'JetBrains Mono',monospace;color:var(--text)}

.banner{padding:clamp(10px,2.5vw,13px) clamp(12px,3vw,15px);border-radius:var(--radius-sm);display:flex;align-items:center;gap:10px;font-size:clamp(12px,3vw,13px);font-weight:600}
.banner svg{width:18px;height:18px;flex-shrink:0;stroke-width:2.2}

.ai-box{background:var(--blue-light);border-radius:var(--radius-sm);padding:clamp(12px,3vw,14px);font-size:clamp(12px,3vw,13px);color:var(--text);line-height:1.65;display:flex;gap:9px;border:1px solid rgba(26,111,212,.15)}
.ai-box svg{width:16px;height:16px;stroke:var(--blue);flex-shrink:0;margin-top:2px;stroke-width:2}

.progress-bg{background:var(--surface2);border-radius:6px;height:8px;overflow:hidden;border:1px solid var(--border)}
.progress-fill{height:100%;border-radius:6px;transition:width .5s cubic-bezier(.4,0,.2,1)}


.scroll-row{display:flex;gap:8px;overflow-x:auto;padding-bottom:4px;-webkit-overflow-scrolling:touch;scrollbar-width:none}
.scroll-row::-webkit-scrollbar{display:none}
.pill{display:flex;gap:6px;padding:8px 12px;background:var(--surface2);border-radius:30px;align-items:center;cursor:pointer;border:1px solid var(--border);flex-shrink:0;font-size:clamp(11px,2.8vw,12px);white-space:nowrap;font-family:'Inter',sans-serif;transition:all .15s}
.pill svg{width:13px;height:13px;stroke:var(--text3);stroke-width:2}
.pill:hover{border-color:var(--blue);color:var(--blue)}

.chat-wrap{display:flex;flex-direction:column;gap:10px;min-height:200px}
.bubble{max-width:90%;padding:11px 15px;border-radius:16px;font-size:var(--fs-sm);line-height:1.6;word-break:break-word}
.bubble.user{background:var(--blue);color:#fff;align-self:flex-end;border-bottom-right-radius:4px}
.bubble.ai{background:var(--surface2);color:var(--text);align-self:flex-start;border-bottom-left-radius:4px;border:1px solid var(--border)}
.chat-input-row{display:flex;gap:8px;margin-top:12px;align-items:center}
.chat-input-row input{flex:1;border-radius:20px;padding:10px 14px;font-family:'Inter',sans-serif}
.chat-send{background:var(--blue);color:#fff;border:none;border-radius:50%;width:40px;height:40px;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.chat-send svg{width:17px;height:17px;stroke:#fff;stroke-width:2.2}

canvas{border-radius:var(--radius-sm);display:block;width:100%}

/* Popup overlay */
.popup-overlay{position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:999;display:none;align-items:flex-end;justify-content:center;backdrop-filter:blur(3px)}
.popup-overlay.show{display:flex}
.popup{background:var(--surface);border-radius:var(--radius-lg) var(--radius-lg) 0 0;padding:20px 20px 32px;width:100%;max-width:480px;box-shadow:0 -8px 32px rgba(0,0,0,.15);animation:slideUp .25s ease;max-height:90vh;overflow-y:auto}
@keyframes slideUp{from{transform:translateY(100%)}to{transform:translateY(0)}}
.popup-handle{width:36px;height:4px;background:var(--border2);border-radius:4px;margin:0 auto 18px}
.doc-section{margin-bottom:16px}
.doc-h{font-size:14px;font-weight:700;color:var(--blue);margin-bottom:5px;display:flex;align-items:center;gap:6px}
.doc-h::before{content:'';width:3px;height:13px;background:var(--blue);border-radius:2px}
.doc-section p{font-size:12.5px;color:var(--text2);line-height:1.6;margin:0 0 5px 0}
.doc-section p strong{color:var(--text)}
.popup-title{font-size:16px;font-weight:700;margin-bottom:6px;color:var(--text)}
.popup-sub{font-size:12px;color:var(--text3);margin-bottom:16px;line-height:1.5}

/* Type toggle */
.type-toggle{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:16px}
.type-btn{padding:12px;border-radius:var(--radius-sm);border:1.5px solid var(--border);background:var(--surface2);cursor:pointer;text-align:center;font-family:'Inter',sans-serif;transition:all .2s}
.type-btn.active{border-color:var(--blue);background:var(--blue-light);color:var(--blue)}
.type-btn .tb-icon{font-size:24px;margin-bottom:4px}
.type-btn .tb-label{font-size:12px;font-weight:600}
.type-btn .tb-sub{font-size:12px;color:var(--text3);margin-top:2px}
.type-btn.active .tb-sub{color:var(--blue);opacity:.7}

/* Category grid */
.cat-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:16px}
.cat-card{padding:12px;border-radius:var(--radius-sm);border:1.5px solid var(--border);background:var(--surface2);cursor:pointer;font-family:'Inter',sans-serif;transition:all .15s}
.cat-card:hover,.cat-card.active{border-color:var(--blue);background:var(--blue-light)}
.cat-card .cc-icon{font-size:22px;margin-bottom:4px}
.cat-card .cc-name{font-size:12px;font-weight:600;color:var(--text)}

/* Part list */
.part-list{display:flex;flex-direction:column;gap:6px;max-height:280px;overflow-y:auto}
.part-item{padding:10px 12px;border-radius:var(--radius-sm);border:1px solid var(--border);background:var(--surface2);cursor:pointer;transition:all .15s}
.part-item:hover,.part-item.active{border-color:var(--blue);background:var(--blue-light)}
.part-item .pi-name{font-size:14px;font-weight:600;color:var(--text)}
.part-item .pi-sub{font-size:13px;color:var(--text3);margin-top:2px}
.part-item .pi-tag{display:inline-block;padding:2px 7px;border-radius:10px;font-size:12px;font-weight:600;margin-top:4px}

/* Hole/Pin */
.fit-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.fit-card{padding:12px;border-radius:var(--radius-sm);border:1.5px solid var(--border);background:var(--surface2);text-align:center;cursor:pointer;transition:all .15s}
.fit-card.active{border-color:var(--blue);background:var(--blue-light)}
.fit-card .fc-sym{font-size:28px;margin-bottom:4px}
.fit-card .fc-name{font-size:12px;font-weight:600}

/* Link item */
.link-item{background:var(--surface);border-radius:var(--radius-sm);border:1px solid var(--border);overflow:hidden;margin-bottom:8px}
.link-header{display:flex;align-items:center;gap:10px;padding:11px 12px;cursor:pointer}
.link-num{width:24px;height:24px;border-radius:50%;background:var(--blue);color:#fff;font-size:13px;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.link-name{flex:1;font-size:var(--fs-sm);font-weight:600;color:var(--text)}
.link-summary{font-size:var(--fs-xs);font-family:'JetBrains Mono',monospace;color:var(--text3);margin-top:1px}
.link-type-badge{font-size:11px;font-weight:700;padding:2px 7px;border-radius:10px;margin-left:6px;flex-shrink:0}
.link-body{padding:12px;border-top:1px solid var(--border);background:var(--surface2)}

.comp-row{margin-bottom:10px}
.comp-label{display:flex;justify-content:space-between;align-items:center;font-size:12px;margin-bottom:4px}
.comp-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;margin-right:4px;display:inline-block}

.hist-bar{flex:1;display:flex;flex-direction:column;align-items:center}
.hist-fill{width:100%;border-radius:2px 2px 0 0;min-height:2px}

.scale-track{position:relative;height:10px;border-radius:6px;background:linear-gradient(to right,#D93025,#F5A623,#3CB371,#1DAA6A);margin:22px 0 8px}
.scale-mark{position:absolute;top:-18px;transform:translateX(-50%);font-size:12px;color:var(--text3);font-weight:600}
.scale-pin{position:absolute;top:-7px;transform:translateX(-50%);width:3px;height:24px;background:var(--text);border-radius:2px}

.contrib-row{display:flex;align-items:center;gap:8px;margin-bottom:6px;font-size:12px}
.contrib-bar-bg{flex:1;height:8px;background:var(--surface2);border-radius:4px;overflow:hidden;border:1px solid var(--border)}
.contrib-bar-fill{height:100%;border-radius:4px}
.contrib-pct{min-width:38px;text-align:right;font-family:'JetBrains Mono',monospace;font-weight:600;font-size:13px}

.gap{height:clamp(8px,2vw,10px)}
.hidden{display:none!important}
.mt8{margin-top:8px}

.ai-mode-btn{display:flex;flex-direction:column;align-items:center;gap:3px;padding:12px 8px;border-radius:var(--radius-sm);border:1.5px solid var(--border);background:var(--surface2);cursor:pointer;font-family:'Inter',sans-serif;transition:all .2s;width:100%}
.ai-mode-btn.active{border-color:var(--blue);background:var(--blue-light)}
.chain-link-preview{background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius-sm);padding:10px 12px;display:flex;align-items:center;gap:10px;position:relative;margin-bottom:2px}
.chain-link-preview::before{content:'';position:absolute;left:22px;top:-8px;width:2px;height:8px;background:var(--border2)}
.chain-link-preview:first-child::before{display:none}
.clp-num{width:22px;height:22px;border-radius:50%;background:var(--blue);color:#fff;font-size:12px;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.clp-body{flex:1;min-width:0}
.clp-name{font-size:var(--fs-sm);font-weight:600;color:var(--text)}
.clp-sub{font-size:var(--fs-xs);color:var(--text3);margin-top:1px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.clp-tol{font-family:'JetBrains Mono',monospace;font-size:12px;font-weight:600;color:var(--blue);white-space:nowrap;margin-left:4px}
.clp-tag{display:inline-block;padding:2px 6px;border-radius:8px;font-size:11px;font-weight:700;margin-top:3px}
/* ── Startseite ── */
.start-screen{position:fixed;inset:0;z-index:4000;background:linear-gradient(160deg,#0a1628 0%,#0f2447 45%,#1A6FD4 120%);overflow-y:auto;display:flex;flex-direction:column;align-items:center;padding:max(40px,env(safe-area-inset-top)) 20px 40px}
.start-screen.hidden{display:none}
.start-inner{width:100%;max-width:440px;display:flex;flex-direction:column;align-items:center}
.start-logo{width:64px;height:64px;border-radius:18px;background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.2);display:flex;align-items:center;justify-content:center;margin-bottom:16px;box-shadow:0 8px 28px rgba(0,0,0,.3)}
.start-title{font-size:24px;font-weight:700;color:#fff;letter-spacing:-0.5px;text-align:center}
.start-sub{font-size:13px;color:#7ee8fa;margin-top:4px;margin-bottom:30px;font-style:italic}
.start-actions{width:100%;display:flex;flex-direction:column;gap:12px}
.start-card{display:flex;align-items:center;gap:14px;width:100%;padding:18px 16px;border-radius:16px;border:1px solid rgba(255,255,255,.15);background:rgba(255,255,255,.08);color:#fff;cursor:pointer;text-align:left;font-family:'Inter',sans-serif;transition:background .15s,transform .08s;-webkit-tap-highlight-color:transparent;backdrop-filter:blur(8px)}
.start-card:active{transform:scale(.98);background:rgba(255,255,255,.14)}
.start-card.primary{background:#fff;color:#0f2447;border-color:#fff}
.start-card svg{width:26px;height:26px;flex-shrink:0;color:currentColor}
.start-card .sc-title{font-size:16px;font-weight:700}
.start-card .sc-sub{font-size:12px;opacity:.7;margin-top:2px;line-height:1.35}
.start-panel{width:100%;background:var(--surface);border-radius:18px;padding:20px;margin-top:4px;box-shadow:0 12px 40px rgba(0,0,0,.3);animation:popIn .2s}
.start-panel.hidden{display:none}
.start-panel-title{font-size:18px;font-weight:700;color:var(--text);margin-bottom:16px}
.carbody-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:8px}
.carbody-opt{display:flex;align-items:center;gap:8px;padding:12px 10px;border:1.5px solid var(--border);border-radius:12px;background:var(--surface2);cursor:pointer;font-size:13px;font-weight:600;color:var(--text2);transition:all .12s;-webkit-tap-highlight-color:transparent}
.carbody-opt.active{border-color:var(--blue);background:var(--blue-light);color:var(--blue)}
.carbody-opt .cb-icon{font-size:20px;line-height:1}
.start-proj-item{display:flex;align-items:center;gap:12px;padding:14px 12px;border:1px solid var(--border);border-radius:12px;margin-bottom:8px;cursor:pointer;transition:background .12s;-webkit-tap-highlight-color:transparent}
.start-proj-item:active{background:var(--blue-light)}
.start-proj-icon{width:40px;height:40px;border-radius:10px;background:var(--blue-light);display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0}
.start-proj-meta{flex:1;min-width:0}
.start-proj-name{font-size:15px;font-weight:700;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.start-proj-sub{font-size:12px;color:var(--text3);margin-top:2px}
.start-proj-del{width:30px;height:30px;border-radius:8px;border:none;background:rgba(217,48,37,.08);color:var(--red);font-size:16px;cursor:pointer;flex-shrink:0;display:flex;align-items:center;justify-content:center}
.orient-catalog{display:grid;grid-template-columns:repeat(2,1fr);gap:8px}
.orient-thumb{border:1.5px solid var(--border);border-radius:10px;overflow:hidden;cursor:pointer;background:#fff;transition:border-color .12s;-webkit-tap-highlight-color:transparent;display:flex;flex-direction:column}
.orient-thumb.active{border-color:var(--blue);box-shadow:0 0 0 2px var(--blue-light)}
.orient-thumb img{width:100%;height:54px;object-fit:contain;background:#fff}
.orient-thumb span{font-size:10px;color:var(--text2);padding:4px 6px;text-align:center;line-height:1.25;border-top:1px solid var(--border)}
/* Toast-Benachrichtigungen (iOS-Stil, nicht blockierend) */
.toast-host{position:fixed;left:0;right:0;bottom:calc(20px + env(safe-area-inset-bottom));z-index:5000;display:flex;flex-direction:column;align-items:center;gap:8px;pointer-events:none;padding:0 16px}
.toast{background:rgba(20,28,40,.96);color:#fff;padding:12px 18px;border-radius:12px;font-size:14px;font-weight:500;box-shadow:0 8px 28px rgba(0,0,0,.3);max-width:440px;width:auto;display:flex;align-items:center;gap:10px;transform:translateY(20px);opacity:0;transition:transform .25s,opacity .25s;pointer-events:auto;backdrop-filter:blur(8px)}
.toast.show{transform:translateY(0);opacity:1}
.toast.success{border-left:3px solid #1DAA6A}
.toast.error{border-left:3px solid #D93025}
.toast.info{border-left:3px solid #4BA3E3}
.toast svg{width:18px;height:18px;flex-shrink:0}
/* Name-Eingabe-Sheet */
.name-sheet-input{width:100%;font-family:'Inter',sans-serif!important;font-size:16px;margin:12px 0}
/* Loop-Richtung */
.dir-btn{padding:6px 10px;font-size:11px;font-weight:700;border:1.5px solid var(--border);border-radius:7px;background:var(--surface);color:var(--text3);cursor:pointer;font-family:'Inter',sans-serif;-webkit-tap-highlight-color:transparent;transition:all .12s}
.dir-btn.active{border-color:#1DAA6A;background:rgba(29,170,106,.1);color:#1DAA6A}
.dir-btn.active.neg{border-color:#D93025;background:rgba(217,48,37,.1);color:#D93025}
/* Loop-Diagramm */
.loop-diagram{position:relative;padding:8px 0;overflow-x:auto}
.loop-row{display:flex;align-items:center;gap:0;min-width:min-content;padding:4px 2px}
.loop-node{display:flex;flex-direction:column;align-items:center;min-width:64px;flex-shrink:0}
.loop-node-box{width:48px;height:48px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:16px;font-weight:700;font-family:'JetBrains Mono',monospace;color:#fff;box-shadow:0 2px 6px rgba(0,0,0,.15)}
.loop-node-lbl{font-size:9px;color:var(--text3);margin-top:4px;text-align:center;max-width:64px;line-height:1.2;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.loop-arrow{flex-shrink:0;display:flex;flex-direction:column;align-items:center;justify-content:center;width:34px;color:var(--text3)}
.loop-arrow svg{width:34px;height:20px}
.loop-arrow-lbl{font-size:9px;font-family:'JetBrains Mono',monospace;margin-top:1px}
/* Tappbare Beitragsleister-Karte (iOS-Stil) */
.chain-link-preview{cursor:pointer;-webkit-tap-highlight-color:transparent;transition:background .12s,transform .08s}
.chain-link-preview:active{background:var(--blue-light);transform:scale(.985)}
.clp-dot{width:9px;height:9px;border-radius:50%;flex-shrink:0;box-shadow:0 0 0 2px var(--surface)}
.clp-right{display:flex;align-items:center;gap:4px;margin-left:6px;flex-shrink:0}
.clp-chevron{width:18px;height:18px;color:var(--text3);flex-shrink:0}
/* Bottom-Sheet */
.sheet-bg{position:fixed;inset:0;background:rgba(0,0,0,0);z-index:3000;display:flex;align-items:flex-end;justify-content:center;transition:background .2s}
.sheet-bg.show{background:rgba(0,0,0,.4)}
.sheet{width:100%;max-width:480px;background:var(--surface);border-radius:20px 20px 0 0;padding:8px 16px calc(16px + env(safe-area-inset-bottom));transform:translateY(100%);transition:transform .25s cubic-bezier(.22,.61,.36,1);box-shadow:0 -4px 24px rgba(0,0,0,.18)}
.sheet-bg.show .sheet{transform:translateY(0)}
.sheet-handle{width:38px;height:5px;border-radius:3px;background:var(--border2);margin:6px auto 12px}
.sheet-head{padding:0 4px 12px;border-bottom:1px solid var(--border);margin-bottom:10px}
.sheet-title{font-size:var(--fs-md);font-weight:700;color:var(--text)}
.sheet-sub{font-size:var(--fs-xs);color:var(--text3);margin-top:3px;line-height:1.4}
.sheet-btn{display:flex;align-items:center;gap:12px;width:100%;padding:14px 12px;border:none;background:var(--surface2);border-radius:12px;margin-bottom:8px;font-size:var(--fs-base);font-weight:600;color:var(--text);cursor:pointer;font-family:'Inter',sans-serif;-webkit-tap-highlight-color:transparent;transition:background .12s}
.sheet-btn:active{background:var(--blue-light)}
.sheet-btn svg{width:22px;height:22px;flex-shrink:0;color:var(--blue)}
.sheet-btn.primary{background:var(--blue);color:#fff}
.sheet-btn.primary svg{color:#fff}
.sheet-btn.primary:active{background:var(--blue-mid)}
.sheet-btn.danger{color:var(--red)}
.sheet-btn.danger svg{color:var(--red)}
.sheet-btn.danger:active{background:rgba(217,48,37,.08)}
.sheet-badge{margin-left:auto;font-size:10px;font-weight:700;color:#fff;padding:2px 8px;border-radius:8px}
.sheet-cancel{width:100%;padding:14px;border:none;background:transparent;border-radius:12px;margin-top:4px;font-size:var(--fs-base);font-weight:700;color:var(--blue);cursor:pointer;font-family:'Inter',sans-serif}
.sheet-cancel:active{background:var(--surface2)}
</style>
</head>
<body>
<div class="app">

<!-- ══ STARTSEITE (Projekt-Auswahl) ══ -->
<div id="start-screen" class="start-screen">
  <div class="start-inner">
    <div class="start-logo">
      <svg viewBox="0 0 24 24" fill="none" style="width:34px;height:34px;stroke:#fff;stroke-width:1.6"><path d="M3 6h18M3 12h18M3 18h18" stroke-linecap="round"/><circle cx="9" cy="12" r="2" fill="#fff" stroke="none"/><circle cx="15" cy="6" r="2" fill="#fff" stroke="none"/></svg>
    </div>
    <div class="start-title">Toleranzmanagement Tool</div>
    <div class="start-sub">by M. Battel · v0.1.0-alpha</div>

    <div id="start-actions" class="start-actions">
      <button class="start-card primary" onclick="openStartScreen('new')">
        <svg viewBox="0 0 24 24" fill="none"><path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/></svg>
        <div><div class="sc-title">Neues Projekt anlegen</div><div class="sc-sub">Karosserieform, Marke & Stückzahl festlegen</div></div>
      </button>
      <button class="start-card" id="start-load-btn" onclick="openStartScreen('load')">
        <svg viewBox="0 0 24 24" fill="none"><path d="M3 7a2 2 0 012-2h4l2 2h8a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V7z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/></svg>
        <div><div class="sc-title">Projekt laden</div><div class="sc-sub"><span id="start-proj-count">0</span> gespeicherte Projekte</div></div>
      </button>
      <button class="start-card" onclick="skipToBuilder()">
        <svg viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <div><div class="sc-title">Ohne Projekt fortfahren</div><div class="sc-sub">Direkt zur Ketten-Erstellung · Zuordnung später möglich</div></div>
      </button>
    </div>

    <!-- Panel: Neues Projekt -->
    <div id="start-new" class="start-panel hidden">
      <div class="start-panel-title">Neues Projekt</div>
      <div class="field-label" style="margin-bottom:5px">Projektname</div>
      <input type="text" id="np-name" placeholder="z.B. Baureihe Heck" style="font-family:'Inter',sans-serif;margin-bottom:12px">
      <div class="field-label" style="margin-bottom:6px">Karosserieform</div>
      <div id="np-carbody" class="carbody-grid"></div>
      <div class="field-label" style="margin:12px 0 5px">Marke</div>
      <select id="np-brand" style="margin-bottom:12px"></select>
      <div class="field-label" style="margin-bottom:5px">Geplante Stückzahl (Jahr)</div>
      <input type="number" inputmode="decimal" id="np-qty" placeholder="z.B. 50000" step="1000" min="1" style="margin-bottom:14px">
      <div style="display:flex;gap:8px">
        <button class="btn ghost" style="flex:1" onclick="backToStart()">Zurück</button>
        <button class="btn" style="flex:2" onclick="submitNewProject()">Projekt erstellen</button>
      </div>
    </div>

    <!-- Panel: Projekt laden -->
    <div id="start-load" class="start-panel hidden">
      <div class="start-panel-title">Projekt laden</div>
      <div id="start-project-list"></div>
      <div style="display:flex;gap:8px;margin-top:10px">
        <button class="btn ghost" style="flex:1" onclick="backToStart()">Zurück</button>
        <label class="btn ghost" style="flex:1;cursor:pointer;text-align:center">Importieren<input type="file" accept="application/json" onchange="importStoreFile(this)" style="display:none"></label>
        <button class="btn ghost" style="flex:1" onclick="exportStore()">Sichern</button>
      </div>
    </div>

    <!-- Panel: Kette zuordnen -->
    <div id="start-assign" class="start-panel hidden">
      <div class="start-panel-title">Kette einem Projekt zuordnen</div>
      <div id="start-assign-list"></div>
      <button class="btn ghost" style="width:100%;margin-top:10px" onclick="backToStart()">Abbrechen</button>
    </div>
  </div>
</div>

<div class="header">
  <div class="brand">
    <div class="brand-name">Automotive · Qualitätsanalyse</div>
    <div class="brand-title">Toleranzmanagement <span>Tool</span></div>
    <div class="brand-author">by M. Battel</div>
    <div class="brand-badge">v0.1.0-alpha</div>
  </div>
  <div class="header-actions">
    <button class="header-gear" onclick="goToStart()" title="Projekte / Startseite" aria-label="Projekte / Startseite">
      <svg viewBox="0 0 24 24" fill="none"><path d="M3 11l9-8 9 8M5 9v11a1 1 0 001 1h4v-6h4v6h4a1 1 0 001-1V9" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
    <button class="header-gear" onclick="toggleDocPanel()" title="Dokumentation" aria-label="Dokumentation">
      <svg viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5"/><path d="M12 16v-4M12 8h.01" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
    </button>
    <button class="header-gear" onclick="toggleKeyPanel()" title="KI-Einstellungen" aria-label="KI-Einstellungen">
      <svg viewBox="0 0 24 24" fill="none"><path d="M12 15a3 3 0 100-6 3 3 0 000 6z" stroke="currentColor" stroke-width="2"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 11-2.83 2.83l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 11-2.83-2.83l.06-.06a1.65 1.65 0 00.33-1.82 1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 112.83-2.83l.06.06a1.65 1.65 0 001.82.33H9a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 112.83 2.83l-.06.06a1.65 1.65 0 00-.33 1.82V9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z" stroke="currentColor" stroke-width="1.5"/></svg>
    </button>
  </div>
</div>

<!-- KI Key Panel -->
<div id="key-panel" class="hidden">
  <div class="key-panel-inner">
    <!-- Sprachumschalter -->
    <div style="display:flex;align-items:center;gap:8px;margin-bottom:14px;padding-bottom:14px;border-bottom:1px solid var(--border)">
      <svg viewBox="0 0 24 24" fill="none" style="width:16px;height:16px;stroke:var(--blue);stroke-width:2"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15 15 0 010 20M12 2a15 15 0 000 20"/></svg>
      <span style="font-weight:600;font-size:14px;color:var(--text)" data-i18n="settings.language">Sprache / Language</span>
      <div style="display:flex;gap:4px;margin-left:auto">
        <button class="lang-btn active" data-lang="de" onclick="setLang('de')">DE</button>
        <button class="lang-btn" data-lang="en" onclick="setLang('en')">EN</button>
      </div>
    </div>
    <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px">
      <svg viewBox="0 0 24 24" fill="none" style="width:16px;height:16px;stroke:var(--blue);stroke-width:2"><path d="M12 2L13.5 8.5L20 7L15.5 12L20 17L13.5 15.5L12 22L10.5 15.5L4 17L8.5 12L4 7L10.5 8.5L12 2Z"/></svg>
      <span style="font-weight:600;font-size:14px;color:var(--text)" data-i18n="settings.ai">KI-Funktionen aktivieren</span>
      <span id="key-status" style="margin-left:auto;font-size:12px;font-weight:700;padding:2px 8px;border-radius:8px;background:#D9302515;color:#D93025" data-i18n="status.inactive">INAKTIV</span>
    </div>
    <div style="font-size:13px;color:var(--text3);line-height:1.5;margin-bottom:10px">
      Ketten-Builder, Topologie & alle Berechnungen funktionieren <strong>ohne Key</strong>. Für KI-Chat & KI-Interpretationen einen Anthropic API Key eintragen (<a href="https://console.anthropic.com/settings/keys" target="_blank" style="color:var(--blue)">console.anthropic.com</a>).
    </div>
    <div style="display:flex;gap:8px">
      <input type="password" id="api-key-input" placeholder="sk-ant-..." style="flex:1;font-family:'JetBrains Mono',monospace;font-size:12px">
      <button class="btn" style="width:auto;padding:0 16px" onclick="saveApiKey()" data-i18n="btn.save">Speichern</button>
    </div>
