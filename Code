// ══ ERWEITERTE KPIs (Reifegrad, Σ-PPM, Top-Risiko, Bestätigung, Cpk-Histogramm) ══
function renderAdvancedKPIs(){
  const chains = project.chains;
  if(!chains.length) return '';
  const withSpec = chains.filter(c=>c.spec);
  const cpks = chains.filter(c=>c.cpk!=null).map(c=>c.cpk);

  // 1) REIFEGRAD: Mittel aus Bestätigungsgrad und Vorgabe-Erfüllung
  let totalLinks=0, confirmedLinks=0;
  chains.forEach(c=>{ (c.links||[]).forEach(l=>{ totalLinks++; if(l.confirmed) confirmedLinks++; }); });
  const confirmRate = totalLinks ? confirmedLinks/totalLinks : 0;
  const gruen = chains.filter(c=>c.status==='grün').length;
  const fulfillRate = withSpec.length ? gruen/withSpec.length : 0;
  // Reifegrad: gewichtet (Erfüllung zählt doppelt, da inhaltlich wichtiger als Bestätigung)
  const maturity = withSpec.length
    ? Math.round((fulfillRate*2 + confirmRate)/3 * 100)
    : Math.round(confirmRate * 100);
  const matCol = maturity>=80?'#1DAA6A':maturity>=50?'#F5A623':'#D93025';
  const matLabel = maturity>=80?'Reif / absicherbar':maturity>=50?'In Arbeit':'Früh / offen';

  // 2) Σ FEHLERFAHRZEUGE: aggregiert über alle Ketten bei Projekt-Stückzahl
  const qty = project.qty || null;
  let totalPpm=0, ppmChains=0;
  chains.forEach(c=>{
    if(c.cpk!=null && c.cpk>0){
      const ppm = Math.max(0, normCDF(-(c.cpk*3-1.5))*1e6);
      totalPpm += ppm; ppmChains++;
    }
  });
  // Wahrscheinlichkeit, dass ein Fahrzeug an MINDESTENS einem Maß außerhalb liegt (1 - Π Gutraten)
  let goodProb=1;
  chains.forEach(c=>{
    if(c.cpk!=null && c.cpk>0){
      const ppm=Math.max(0, normCDF(-(c.cpk*3-1.5))*1e6);
      goodProb *= (1 - ppm/1e6);
    }
  });
  const anyDefectRate = 1 - goodProb;          // P(mind. 1 Maß außerhalb)
  const defectVehicles = qty ? Math.round(anyDefectRate*qty) : null;
  const defCol = anyDefectRate<0.01?'#1DAA6A':anyDefectRate<0.05?'#F5A623':'#D93025';

  // 3) TOP-RISIKO: Kette mit niedrigstem Cpk
  let worst=null;
  chains.forEach(c=>{ if(c.cpk!=null && (worst===null || c.cpk<worst.cpk)) worst=c; });
  let worstDriver='';
  if(worst && worst.links){
    // größter Varianzbeitrag
    let maxVar=-1, drv=null;
    worst.links.forEach(l=>{ const v=Math.pow((l.upper-l.lower)/2*(l.distributionFactor||1),2); if(v>maxVar){maxVar=v;drv=l;} });
    if(drv) worstDriver=drv.name;
  }

  // 4) Cpk-HISTOGRAMM
  const bands=[
    {lbl:'<1.0', min:-Infinity, max:1.0, col:'#D93025'},
    {lbl:'1.0–1.33', min:1.0, max:1.33, col:'#F5A623'},
    {lbl:'1.33–1.67', min:1.33, max:1.67, col:'#1DAA6A'},
    {lbl:'≥1.67', min:1.67, max:Infinity, col:'#0a8f56'},
  ];
  const bandCounts = bands.map(b=> cpks.filter(v=>v>=b.min && v<b.max).length);
  const maxBand = Math.max(1, ...bandCounts);

  return `
    <!-- Reifegrad -->
    <div style="background:var(--surface2);border:1px solid var(--border);border-left:3px solid ${matCol};border-radius:10px;padding:12px;margin-bottom:10px">
      <div style="display:flex;align-items:center;gap:10px">
        <div style="position:relative;width:54px;height:54px;flex-shrink:0">
          <svg viewBox="0 0 36 36" style="width:54px;height:54px;transform:rotate(-90deg)">
            <circle cx="18" cy="18" r="15.5" fill="none" stroke="var(--border)" stroke-width="3"/>
            <circle cx="18" cy="18" r="15.5" fill="none" stroke="${matCol}" stroke-width="3" stroke-linecap="round" stroke-dasharray="${maturity/100*97.4} 97.4"/>
          </svg>
          <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:700;color:${matCol}">${maturity}%</div>
        </div>
        <div style="flex:1">
          <div style="font-size:14px;font-weight:700;color:var(--text)">Reifegrad: ${matLabel}</div>
          <div style="font-size:12px;color:var(--text3);margin-top:2px;line-height:1.4">${withSpec.length?`${Math.round(fulfillRate*100)}% Vorgaben erfüllt · `:''}${Math.round(confirmRate*100)}% Toleranzen bestätigt</div>
        </div>
      </div>
    </div>

    <!-- Σ Fehlerfahrzeuge + Bestätigung -->
    <div class="row2" style="margin-bottom:10px">
      <div class="metric" style="background:${defCol}10">
        <div class="metric-val" style="color:${defCol};font-size:18px">${defectVehicles!==null?defectVehicles.toLocaleString('de'):(ppmChains?Math.round(anyDefectRate*1e6).toLocaleString('de')+' PPM':'–')}</div>
        <div class="metric-lbl">${defectVehicles!==null?'Fzg. mit Abweichung':'Fehlerrate (Σ)'}</div>
      </div>
      <div class="metric">
        <div class="metric-val" style="color:${confirmRate>=0.8?'#1DAA6A':confirmRate>=0.5?'#F5A623':'#D93025'};font-size:18px">${Math.round(confirmRate*100)}%</div>
        <div class="metric-lbl">Toleranzen bestätigt</div>
      </div>
    </div>
    ${defectVehicles!==null?`<div style="font-size:11px;color:var(--text3);margin:-4px 0 10px;line-height:1.4">≈ ${defectVehicles.toLocaleString('de')} von ${qty.toLocaleString('de')} Fahrzeugen mit mind. einem Maß außerhalb (alle Schließmaße kombiniert, 1.5σ-Shift).</div>`:''}

    <!-- Top-Risiko -->
    ${worst ? `<div style="background:var(--surface2);border:1px solid var(--border);border-radius:10px;padding:10px 12px;margin-bottom:10px">
      <div style="display:flex;align-items:center;gap:8px">
        <span style="font-size:18px">${worst.cpk>=1.33?'✅':worst.cpk>=1.0?'⚠️':'⛔'}</span>
        <div style="flex:1;min-width:0">
          <div style="font-size:11px;font-weight:700;color:var(--text3);text-transform:uppercase;letter-spacing:.4px">Schwächstes Schließmaß</div>
          <div style="font-size:14px;font-weight:600;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${worst.name}</div>
          ${worstDriver?`<div style="font-size:12px;color:var(--text3)">Haupttreiber: ${worstDriver}</div>`:''}
        </div>
        <div style="font-family:'JetBrains Mono',monospace;font-weight:700;font-size:18px;color:${worst.cpk>=1.33?'#1DAA6A':worst.cpk>=1.0?'#F5A623':'#D93025'}">${worst.cpk.toFixed(2)}</div>
      </div>
    </div>`:''}

    <!-- Cpk-Histogramm -->
    ${cpks.length?`<div style="margin-bottom:12px">
      <div style="font-size:13px;font-weight:600;color:var(--text3);margin-bottom:8px;text-transform:uppercase;letter-spacing:.4px">Cpk-Verteilung</div>
      <div style="display:flex;align-items:flex-end;gap:6px;height:70px">
        ${bands.map((b,i)=>`<div style="flex:1;display:flex;flex-direction:column;align-items:center;justify-content:flex-end;height:100%">
          <div style="font-size:11px;font-weight:700;color:${b.col};margin-bottom:2px">${bandCounts[i]||''}</div>
          <div style="width:100%;height:${bandCounts[i]/maxBand*46}px;min-height:${bandCounts[i]?'4px':'0'};background:${b.col};border-radius:4px 4px 0 0"></div>
        </div>`).join('')}
      </div>
      <div style="display:flex;gap:6px;margin-top:4px">
        ${bands.map(b=>`<div style="flex:1;text-align:center;font-size:9px;color:var(--text3)">${b.lbl}</div>`).join('')}
      </div>
    </div>`:''}`;
}

