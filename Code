// Berechnet Kennzahlen für Export
function getExportSummary(){
  const d = window._exportData || {};
  const rss = d.rss || Math.sqrt(links.reduce((a,l)=>a+Math.pow((l.upper-l.lower)/2*(l.distributionFactor||1),2),0));
  const nom = d.nom != null ? d.nom : links.reduce((a,l)=>a+l.nom,0);
  const wcHalf = (d.wcR||links.reduce((a,l)=>a+(l.upper-l.lower),0))/2;
  const ist3 = rss, ist4 = rss*4/3;
  let cpk=null, status='–', util=null;
  if(chainSpec){
    const sigma=(rss*2)/6;
    cpk = sigma>0 ? chainSpec.tol/(3*sigma) : 99;
    util = (ist3/chainSpec.tol)*100;
    status = (util<=100&&cpk>=chainSpec.cpk)?'Erfüllt':(util<=110||cpk>=chainSpec.cpk*0.9)?'Grenzwertig':'Nicht erfüllt';
  }
  return {nom, wcHalf, ist3, ist4, cpk, status, util};
}

