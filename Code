}

// Lädt gespeicherte Kette und öffnet direkt den Export
function exportSavedChain(i){
  const c = project.chains[i];
  links = JSON.parse(JSON.stringify(c.links));
  chainSpec = c.spec ? {...c.spec} : null;
  window._exportData = {nom:c.nom, wcR:c.wcHalf*2, rssR:c.ist3*2, rss:c.ist3};
  document.getElementById('export-popup').style.display='flex';
}

function deleteChain(i){
  const name = project.chains[i] ? project.chains[i].name : 'Schließmaß';
  confirmSheet('Schließmaß löschen', `„${name}" wird aus dem Projekt entfernt.`, 'Löschen', function(){
    project.chains.splice(i,1);
    persistStore();
    renderKPI();
    toast('Schließmaß gelöscht.','info');
  });
}

function exportProjectJSON(){
  if(!project.chains.length){ toast('Keine gespeicherten Schließmaße.','info'); return; }
  const data = JSON.stringify(project, null, 2);
  const blob = new Blob([data], {type:'application/json'});
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = (project.name||'Toleranzprojekt').replace(/\s+/g,'_')+'.json';
  a.click();
  URL.revokeObjectURL(url);
}

