async function selectPart(part){
  selectedPart=part;
  document.getElementById('part-config').classList.remove('hidden');
  const mfg = MFG_TOL[part.mfg]||MFG_TOL.custom;
  document.getElementById('sel-part-name').textContent=`${part.name}`;
  document.getElementById('sel-part-info').textContent=`${part.process} · ${mfg.label} · Typisch ${mfg.typical}`;

  // Material-Dropdown füllen (übliche Materialien für dieses Verfahren)
  const matKeys = MFG_MATERIALS[part.mfg] || MFG_MATERIALS.custom;
  const matSel = document.getElementById('cfg-material');
  if(matKeys && matKeys.length){
    document.getElementById('material-select-wrap').style.display='';
    matSel.innerHTML = matKeys.map(k=>`<option value="${k}">${MATERIAL_DB[k].label}</option>`).join('');
    matSel.selectedIndex = 0;
    document.getElementById('material-note').textContent = MATERIAL_DB[matKeys[0]].note;
  } else {
    document.getElementById('material-select-wrap').style.display='none';
  }

  // Presets + Default mit Materialfaktor
  refreshPresetsWithMaterial();
  document.getElementById('cfg-nom').value='0';
  // Walze aufbauen + auf aktuellen Wert setzen
  buildWheelInstance('cfg');
  updateCfgWheel(parseDE((document.getElementById('cfg-tol')||{}).value)||0.3);
  // KI suggestion
  await getAISuggestion(part);
}

function currentMaterialFactor(){
  const sel = document.getElementById('cfg-material');
  if(!sel || sel.style.display==='none' || !sel.value) return 1.0;
  const mat = MATERIAL_DB[sel.value];
  return mat ? mat.factor : 1.0;
}

function onMaterialChange(){
  const sel = document.getElementById('cfg-material');
  const mat = MATERIAL_DB[sel.value];
  if(mat) document.getElementById('material-note').textContent = mat.note;
  refreshPresetsWithMaterial();
}

function refreshPresetsWithMaterial(){
  if(!selectedPart) return;
  const factor = currentMaterialFactor();
  const adjustedTol = +(selectedPart.tol * factor).toFixed(3);
  const presets = getPresets({tol: adjustedTol});
  document.getElementById('preset-btns').innerHTML = presets.map(v=>
    `<button class="btn ghost sm" onclick="applyPartPreset(${v})">±${v}</button>`
  ).join('') + `<span style="font-size:12px;color:var(--text3);align-self:center;margin-left:4px">Faktor ×${factor.toFixed(2)}</span>`;
  applyPartPreset(adjustedTol);
}

function getPresets(part){
  const base = part.tol;
  return [+(base*0.5).toFixed(3), base, +(base*1.5).toFixed(3), +(base*2).toFixed(3)];
}

function applyPartPreset(v){
  document.getElementById('cfg-tol').value=v;
  document.getElementById('cfg-upper').value=+v;
  document.getElementById('cfg-lower').value=-+v;
  updateCfgWheel(+v);
}
function syncPopupTol(){
  const v=parseDE(document.getElementById('cfg-tol').value)||0;
