        <div class="stat-row"><span class="stat-lbl">Vorgabe (Soll)</span><span class="stat-val">${s.nom?fmt(s.nom,1)+'mm ':''}±${fmt(s.tol,1)} mm</span></div>
        <div class="stat-row"><span class="stat-lbl">Ist statistisch (${sigmaLabel()})</span><span class="stat-val" style="color:${utilRSS<=100?'#1DAA6A':'#D93025'}">${fmtSigma(ist3sigma)}</span></div>
        <div class="stat-row"><span class="stat-lbl">Cpk (Schätzung / Ziel)</span><span class="stat-val" style="color:${cpkEst>=s.cpk?'#1DAA6A':cpkEst>=s.cpk*0.9?'#F5A623':'#D93025'}">${fmt(cpkEst,2)} / ${fmt(s.cpk,2)}</span></div>
        <div class="stat-row"><span class="stat-lbl">Reserve</span><span class="stat-val" style="color:${reserve>=0?'#1DAA6A':'#D93025'}">${reserve>=0?'+':''}${fmt(reserve,3)} mm</span></div>
      </div>
    </div>`;
}

function mcSample(type,half){
  switch(type){
    case 'normal':{const u1=Math.random(),u2=Math.random();return Math.sqrt(-2*Math.log(u1))*Math.cos(2*Math.PI*u2)*(half/3);}
    case 'uniform':return(Math.random()*2-1)*half;
    case 'triangular':{const u=Math.random();return u<0.5?-half+Math.sqrt(u*2)*half:half-Math.sqrt((1-u)*2)*half;}
    default:return 0;
  }
}

