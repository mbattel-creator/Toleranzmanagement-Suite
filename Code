// Normalisiert Bauteilnamen → Topologie-Schlüssel
function resolveTopoKey(name){
  if(!name) return null;
  const n = name.toLowerCase().trim()
    .replace(/\bteil\s*\d+\b/g,'').replace(/\bteil\s*[ab]\b/g,'')
    .replace(/\s*\d+\s*$/,'')
    .replace(/\b(links|rechts|li\.|re\.)\b/g,'')
    .replace(/\bvorne\b/g,'vorn')
    .replace(/\s+/g,' ').trim();
  if(!n || n.length < 3) return null;

  // Wortgrenze: nächstes Zeichen nach Treffer muss Leerzeichen, / oder ( sein
  // Verhindert: "a-säule" matcht auf "a-säulenverkleidung"
  function wb(str, sub){
    if(!str.startsWith(sub)) return false;
    if(str.length === sub.length) return true;
    const c = str[sub.length];
    return c === ' ' || c === '/' || c === '(';
  }

  // 1. Exakter Treffer
  if(TOPOLOGY[n]) return n;

  // 2. Schlüssel-Matching — längste zuerst (spezifischer vor allgemein)
  const keys = Object.keys(TOPOLOGY).sort((a,b) => b.length - a.length);
  for(const key of keys){
    if(wb(n, key) || wb(key, n)) return key;
  }

  // 3. Aka-Synonyme — längste zuerst
  const entries = Object.entries(TOPOLOGY).sort((a,b) => {
    const la = Math.max(0, ...(a[1].aka || []).map(x => x.length));
    const lb = Math.max(0, ...(b[1].aka || []).map(x => x.length));
    return lb - la;
  });
  for(const [key, data] of entries){
    for(const aka of (data.aka || [])){
      if(n === aka || wb(n, aka) || wb(aka, n)) return key;
    }
  }
  return null;
}

// BFS-Pfadsuche: kürzeste Bauteilkette zwischen A und B im Topologie-Graph

// Ermittelt die Träger-Kette eines Bauteils bis zum Backbone
// z.B. Stoßfänger hinten → Stoßfängerträger hinten → Crashbox hinten → Längsträger hinten
function carrierChainToBackbone(key){
  const chain = [];
  let current = key;
  const guard = new Set();
  while(current && !guard.has(current)){
    guard.add(current);
    const node = TOPOLOGY[current];
    if(!node) break;
    chain.push(current);
    if(node.layer === 'backbone') break;     // Backbone erreicht
    if(!node.carrier) break;                  // kein Träger definiert → Ende
    current = node.carrier;
  }
  return chain; // [skin, carrier, ..., backbone]
}

// BFS nur im Backbone-Graph (Karosseriestruktur)
function backbonePath(keyA, keyB){
  if(keyA === keyB) return [keyA];
  const queue = [[keyA]];
  const visited = new Set([keyA]);
  while(queue.length){
    const path = queue.shift();
    const last = path[path.length-1];
    const node = TOPOLOGY[last];
    if(!node || !node.neighbors) continue;
    for(const nb of node.neighbors){
      const nbNode = TOPOLOGY[nb];
      if(!nbNode || nbNode.layer !== 'backbone' || visited.has(nb)) continue;
      const np = [...path, nb];
      if(nb === keyB) return np;
      visited.add(nb);
      queue.push(np);
    }
  }
  return null;
}

// Baut die vollständige, fachlich korrekte Toleranzkette über die Unterstruktur:
// Sichtbauteil A → Träger A → ... → Backbone A → (Karosserie) → Backbone B → ... → Träger B → Sichtbauteil B
// BIW-Modus: 'auto' (Standard, Karosserie nur bei versch. Bereichen), 'detail' (alle Träger einzeln), 'biwonly' (nur BIW)
let biwMode = 'auto';
function setBiwMode(m){
  biwMode = m;
  document.querySelectorAll('.biw-opt').forEach(o=>o.classList.toggle('active', o.dataset.biw===m));
  // Falls Kette aufgebaut: neu bauen
  if(typeof aiBuiltLinks!=='undefined' && aiBuiltLinks.length){
    const a=(document.getElementById('part-a')||{}).value||'';
    const b=(document.getElementById('part-b')||{}).value||'';
    if(a&&b && typeof buildChainWithAI==='function'){
      const local=buildChainFromTopology(a,b);
      if(local){ aiBuiltLinks=local; renderBuilderPreview(a,b,aiBuiltLinks,false); }
    }
  }
}

function buildChainFromTopology(partA, partB){
  const keyA = resolveTopoKey(partA);
  const keyB = resolveTopoKey(partB);
  if(!keyA || !keyB) return null;

  // SONDERFALL zweigeteiltes Bauteil (z.B. Heckleuchte: ein Teil an Heckklappe, eines an Seitenwand/Karosserie)
  let cKeyA = keyA, cKeyB = keyB;
  if(keyA === keyB){
    const node = TOPOLOGY[keyA];
    if(!node) return null;
    // Suche eine explizite "Klappen-Variante" des gleichen Bauteiltyps (Sichtbauteil, anderer Carrier)
    const baseWord = keyA.split(' ')[0]; // z.B. 'heckleuchte'
    const variant = Object.keys(TOPOLOGY).find(k=>
      k !== keyA &&
      TOPOLOGY[k].layer === 'skin' &&
      (k.includes(baseWord) || (TOPOLOGY[k].aka||[]).some(a=>a.includes(baseWord))) &&
      TOPOLOGY[k].carrier && TOPOLOGY[k].carrier !== node.carrier
    );
    if(variant){
      cKeyB = variant; // Teil 2 sitzt auf anderem Träger (z.B. Heckklappe)
    } else {
      return buildSplitFallback(partA, partB, node);
    }
  }

  // Träger-Ketten beider Bauteile zum Backbone
  const carA = carrierChainToBackbone(cKeyA); // [skin..backbone]
  const carB = carrierChainToBackbone(cKeyB);
  const backboneA = carA[carA.length-1];
  const backboneB = carB[carB.length-1];

  // Pfad durch die Karosserie zwischen den beiden Backbone-Ankern
  let bonePath = backbonePath(backboneA, backboneB);
  if(!bonePath){
    // Falls Backbone-Anker nicht verbunden: generischer Pfad nicht möglich
    bonePath = (backboneA === backboneB) ? [backboneA] : [backboneA, backboneB];
  }

  // Kette zusammenbauen
  const chain = [];
  const labelOf = (key) => (key===cKeyA?partA : key===cKeyB?partB : cap(key));
  const boneKeys = new Set([backboneA, backboneB, ...bonePath]);

  // ── BIW-Modus 'biwonly': reine Karosserie-interne Kette (nur Backbone-Glieder) ──
  if(biwMode === 'biwonly'){
    const bk = [...boneKeys];
    bk.forEach((key,idx)=>{
      const node = TOPOLOGY[key];
      if(!node) return;
      chain.push(mkNode(cap(key), node, `BIW-Struktur: ${cap(key)} (${node.mfg})`));
      if(idx < bk.length-1){
        const nb = TOPOLOGY[bk[idx+1]];
        chain.push(mkMount(cap(key), cap(bk[idx+1]), Math.max(node.mountTol||0.5, 0.5)));
      }
    });
    return chain.length>=2 ? chain : null;
  }

  // Hilfsfunktion: Karosserie-Glieder anhängen – je nach Modus EIN Glied oder alle Träger einzeln
  const sameRegion = (backboneA === backboneB) && bonePath.length<=1;
  function pushKarosserie(){
    // 'auto' + gleiche Region: keine separate Karosserie (Bauteile sitzen am selben Bereich)
    if(biwMode==='auto' && sameRegion) return;
    if(biwMode==='detail'){
      // Alle Backbone-Teile einzeln auflisten
      const bk=[...boneKeys];
      bk.forEach((key,idx)=>{
        const node=TOPOLOGY[key]; if(!node) return;
        chain.push(mkNode(cap(key), node, `Karosserie-Struktur: ${cap(key)} (${node.mfg})`));
        if(idx<bk.length-1) chain.push(mkMount(cap(key), cap(bk[idx+1]), 0.5));
      });
    } else {
      // Standard: EIN zusammengefasstes Karosserie-Glied
      const karosserieTol = Math.sqrt([...boneKeys].reduce((a,k)=>{
        const t=TOPOLOGY[k]; return a + (t?t.tol*t.tol:0);
      },0));
      chain.push({
        name:'Karosserie', process:'Karosseriestruktur (BIW, geschweißt)', mfg:'welding',
        nom:0, upper:+karosserieTol.toFixed(3), lower:-+karosserieTol.toFixed(3), type:'bauteil',
        reason:`Zusammengefasste Karosserie-Bezugskette (${[...boneKeys].map(cap).join(', ')})`
      });
    }
  }

  // 1. Sichtbauteil A nach unten zu (aber ohne) den Backbone-Anker.
  const karoLabel = (biwMode==='detail') ? cap(backboneA) : 'Karosserie';
  for(let i=0; i<carA.length-1; i++){
    const key = carA[i];
    const node = TOPOLOGY[key];
    const nextIsBackbone = (i+1 === carA.length-1);
    chain.push(mkNode(labelOf(key), node, i===0
      ? `Eigentoleranz ${labelOf(key)} (Sichtbauteil, ${node.mfg})`
      : `Träger/Halter: ${cap(key)} (${node.mfg})`));
    // Wenn gleiche Region & auto: Montage direkt A↔B-Träger, sonst auf Karosserie
    const target = nextIsBackbone
      ? ((biwMode==='auto'&&sameRegion) ? cap(backboneA) : karoLabel)
      : cap(carA[i+1]);
    chain.push(mkMount(labelOf(key), target, node.mountTol||0.4));
  }

  // 2. KAROSSERIE (je nach Modus)
  pushKarosserie();

  // 3. Backbone B hoch zum Sichtbauteil B
  const karoLabelB = (biwMode==='detail') ? cap(backboneB) : 'Karosserie';
  for(let i=carB.length-2; i>=0; i--){
    const key = carB[i];
    const node = TOPOLOGY[key];
    const fromIsBackbone = (i+1===carB.length-1);
    const from = fromIsBackbone
      ? ((biwMode==='auto'&&sameRegion) ? cap(backboneB) : karoLabelB)
      : cap(carB[i+1]);
    chain.push(mkMount(from, labelOf(key), node.mountTol||0.4));
    chain.push(mkNode(labelOf(key), node, i===0
      ? `Eigentoleranz ${labelOf(key)} (Sichtbauteil, ${node.mfg})`
      : `Träger/Halter: ${cap(key)} (${node.mfg})`));
  }

  return chain.length>=2 ? chain : null;
}

// Fallback für zweigeteilte Bauteile ohne explizite Variante
function buildSplitFallback(partA, partB, node){
  const carriers = (node.neighbors||[]).filter(n=>{
    const t=TOPOLOGY[n]; return t && t.layer==='backbone';
  });
  if(carriers.length < 1) return null;
  const cA = carriers[0];
  const cB = carriers[1] || carriers[0];
  const bone = backbonePath(cA, cB) || [cA, cB];
  const boneKeys = new Set([cA, cB, ...bone]);
  const karosserieTol = Math.sqrt([...boneKeys].reduce((a,k)=>{const t=TOPOLOGY[k];return a+(t?t.tol*t.tol:0);},0));
  const chain = [];
  chain.push(mkNode(partA, node, `Eigentoleranz ${partA} (Sichtbauteil)`));
  chain.push(mkMount(partA, 'Karosserie', node.mountTol||0.4));
  chain.push({name:'Karosserie', process:'Karosseriestruktur (BIW, geschweißt)', mfg:'welding', nom:0, upper:+karosserieTol.toFixed(3), lower:-+karosserieTol.toFixed(3), type:'bauteil', reason:`Zusammengefasste Karosserie-Bezugskette (${[...boneKeys].map(cap).join(', ')})`});
  chain.push(mkMount('Karosserie', partB, node.mountTol||0.4));
  chain.push(mkNode(partB, node, `Eigentoleranz ${partB} (Sichtbauteil)`));
  return chain;
}

function cap(key){ return key.charAt(0).toUpperCase() + key.slice(1); }
function mkNode(name, node, reason){
  return {name, process:mfgLabelOf(node.mfg), mfg:node.mfg, nom:0, upper:node.tol, lower:-node.tol, type:'bauteil', reason};
}
function mkMount(fromName, toName, tol){
  return {name:`Montage ${fromName} → ${toName}`, process:'Montage / Schnittstelle', mfg:'assembly', nom:0, upper:tol, lower:-tol, type:'montage', reason:`Montagetoleranz an der Schnittstelle (±${tol.toFixed(1)}mm)`};
}

function mfgLabelOf(mfg){
  const map={stamping:'Tiefziehen Stahl/Alu',injection:'Spritzguss',welding:'Schweißkonstruktion',casting:'Druckguss',glass:'Verglasung',thermoform:'Thermoformen',extrusion:'Extrusion',assembly:'Montagegruppe'};
  return map[mfg]||mfg;
}

function findLocalTemplate(partA, partB){
  const a = partA.toLowerCase().replace(/\s+/g,'').replace('vorn','').replace('hinten','').replace('vorne','');
  const b = partB.toLowerCase().replace(/\s+/g,'').replace('vorn','').replace('hinten','').replace('vorne','');
  for(const [key, chain] of Object.entries(CHAIN_TEMPLATES)){
    if(key === 'default') continue;
    const parts = key.split('|');
    if((a.includes(parts[0])||parts[0].includes(a)) && (b.includes(parts[1])||parts[1].includes(b))) return chain;
    if((b.includes(parts[0])||parts[0].includes(b)) && (a.includes(parts[1])||parts[1].includes(a))) return [...chain].reverse();
  }
  return null;
}

function applyNamesToTemplate(chain, partA, partB){
  const result = JSON.parse(JSON.stringify(chain)); // deep copy
  if(result.length >= 1) result[0].name = partA;
  if(result.length >= 2) result[result.length-1].name = partB;
  return result;
}

