        <div><span class="wheel-val" id="edit-wheel-val">±${cur.toFixed(1)}</span><span style="font-size:13px;color:var(--text3)"> mm</span></div>
      </div>
      <div class="wheel-picker">
        <div class="wheel-track" id="edit-wheel-track" data-wheel-key="edit"
             ontouchstart="wheelTouchKey(event,'start')" ontouchmove="wheelTouchKey(event,'move')" ontouchend="wheelTouchKey(event,'end')"
             onmousedown="wheelMouseKey(event,'down')" onmousemove="wheelMouseKey(event,'move')" onmouseup="wheelMouseKey(event,'up')" onmouseleave="wheelMouseKey(event,'up')"></div>
        <div class="wheel-center-line"></div>
      </div>
      <input type="number" id="edit-tol-input" value="${cur.toFixed(1)}" step="0.1" inputmode="decimal" style="margin-top:8px;text-align:center" oninput="updateWheelInstance('edit', parseDE(this.value))">
    </div>
    <button class="sheet-btn primary" onclick="sheetSaveTol()">
      <svg viewBox="0 0 24 24" fill="none"><path d="M5 12l5 5L19 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      <span>Übernehmen</span>
    </button>
    <button class="sheet-cancel" onclick="closeLinkSheet()">Abbrechen</button>`;
  _wheelReg('edit', {idx:2, prefix:()=>'±', onChange:(v)=>{ const f=document.getElementById('edit-tol-input'); if(f)f.value=v.toFixed(1); }});
  buildWheelInstance('edit');
  updateWheelInstance('edit', cur);
}
function sheetSaveTol(){
  if(_sheetIdx==null) return;
  const v = parseDE((document.getElementById('edit-tol-input')||{}).value);
  if(!isNaN(v) && v>0){
    aiBuiltLinks[_sheetIdx].upper = Math.round(v*10)/10;
    aiBuiltLinks[_sheetIdx].lower = -Math.round(v*10)/10;
  }
  closeLinkSheet(); refreshBuilderResult();
}

// Re-render preview + evaluation (so Ampel/% updates live)
function refreshBuilderResult(){
  const partA = document.getElementById('part-a').value.trim();
  const partB = document.getElementById('part-b').value.trim();
  renderBuilderPreview(partA, partB, aiBuiltLinks, false);
}

// Toleranzvorgabe global merken für Kette-Tab (chainSpec ist global in Block 1 deklariert)

function adoptAIChain(){
  if(!aiBuiltLinks.length){ toast('Keine Kette vorhanden.','error'); return; }
  saveChainSpec();
  links = aiBuiltLinks.map(l => ({
    name: l.name,
    nom: parseFloat(l.nom) || 0,
    upper: parseFloat(l.upper),
    lower: parseFloat(l.lower),
    type: l.type || 'bauteil',
    mfg: l.mfg || 'custom',
    process: l.process || '',
    distributionFactor: l.type === 'holepin' ? 1/Math.sqrt(3) : 1
  }));
  renderLinks();
  showTab('tc');
  setTimeout(calcTC, 100);
}

// Parst Zahl mit Dezimalkomma ODER Punkt (iOS-DE-Tastatur liefert Komma)
function parseDE(v){ return parseFloat(String(v).replace(',','.')); }

function saveChainSpec(){
  const nom = parseDE(document.getElementById('spec-nom').value);
  const tol = parseDE(document.getElementById('spec-tol').value);
  const cpk = parseDE(document.getElementById('spec-cpk').value);
  if(!isNaN(tol) && tol > 0){
    chainSpec = { nom: isNaN(nom)?0:nom, tol, cpk: isNaN(cpk)?1.33:cpk };
  } else {
    chainSpec = null;
  }
}

function addToExisting(){
  if(!aiBuiltLinks.length){ toast('Keine Kette vorhanden.','error'); return; }
  saveChainSpec();
  const toAdd = aiBuiltLinks.map(l => ({
    name: l.name,
    nom: parseFloat(l.nom) || 0,
    upper: parseFloat(l.upper),
    lower: parseFloat(l.lower),
    type: l.type || 'bauteil',
    mfg: l.mfg || 'custom',
    process: l.process || '',
    distributionFactor: l.type === 'holepin' ? 1/Math.sqrt(3) : 1
  }));
  links = [...links, ...toAdd];
  renderLinks();
  showTab('tc');
}

// Spin animation for loading
const spinStyle = document.createElement('style');
spinStyle.textContent = '@keyframes spin{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}';
document.head.appendChild(spinStyle);

// i18n: Initiale Sprache anwenden
applyLang();
// Anwenderlevel initial setzen (app-weit)
setUserLevel(userLevel);
// Spec-Slider Initialzustand
buildWheel();(function(){const v=parseDE((document.getElementById('spec-tol')||{}).value);if(v>0)updateSpecTrack(v);else setWheelIndex(4,false);})();if(typeof updateSpecLabels==='function')updateSpecLabels();
// Datenhaltung laden + Startseite zeigen
loadStore();
syncProjectFieldsToUI();
showStartScreen();
</script>

