function calcHolePin(){
  const nom=parseFloat(document.getElementById('hp-nom').value)||10;
  const hCode=document.getElementById('hp-hole').value;
  const pCode=document.getElementById('hp-pin').value;
  hpCalcResult=calcISO(nom,hCode,pCode);
  if(!hpCalcResult){document.getElementById('hp-result-preview').innerHTML='<div style="color:#D93025">Berechnung fehlgeschlagen</div>';return;}
  const r=hpCalcResult;
  const fitName = r.isInterference?'Presspassung':'Spielpassung';
  const fitColor = r.isInterference?'#D93025':'#1DAA6A';
  document.getElementById('hp-result-preview').innerHTML=`
    <div style="font-size:12px;font-weight:700;color:${fitColor};margin-bottom:8px">${hCode}/${pCode} – ${fitName} (∅${nom}mm)</div>
    <div class="stat-row"><span class="stat-lbl">Bohrung (+)</span><span class="stat-val">+${r.holeUpper.toFixed(3)} / 0</span></div>
    <div class="stat-row"><span class="stat-lbl">Welle</span><span class="stat-val">${r.shaftUpper>=0?'+':''}${r.shaftUpper.toFixed(3)} / ${r.shaftLower.toFixed(3)}</span></div>
    <div class="stat-row"><span class="stat-lbl">${r.isInterference?'Übermaß':'Spiel'} max</span><span class="stat-val" style="color:${fitColor}">${Math.abs(r.maxClearance).toFixed(1)} mm</span></div>
    <div class="stat-row"><span class="stat-lbl">${r.isInterference?'Übermaß':'Spiel'} min</span><span class="stat-val" style="color:${fitColor}">${Math.abs(r.minClearance).toFixed(1)} mm</span></div>
    <div style="font-size:13px;color:var(--text3);margin-top:6px">Rechteckverteilung wird in Toleranzkette übernommen</div>`;
  document.getElementById('hp-confirm').classList.remove('hidden');
}

function confirmHolePin(){
  if(!hpCalcResult)return;
  const nom=parseFloat(document.getElementById('hp-nom').value)||10;
  const hCode=document.getElementById('hp-hole').value;
  const pCode=document.getElementById('hp-pin').value;
  const r=hpCalcResult;
  // Resultierende Toleranz als Rechteckverteilung (Spielbereich / 2)
  const range=(r.maxClearance-r.minClearance);
  const mid=(r.maxClearance+r.minClearance)/2;
  const halfRange=range/2;
  links.push({
    name:`Passung ${hCode}/${pCode} ∅${nom}mm`,
    nom, upper:mid+halfRange, lower:mid-halfRange,
    type:'holepin', mfg:'assembly', process:`ISO ${hCode}/${pCode}`,
    distributionFactor: 1/Math.sqrt(3), confirmed: false // Rechteckverteilung für RSS
  });
  renderLinks();closeAddPopup();
}

