function setReqClass(c){
  reqClass = c;
  document.querySelectorAll('.req-class-btn').forEach(b=>b.classList.toggle('active', b.dataset.class===c));
  const desc = document.getElementById('req-class-desc');
  const shortTxt={visual:'Optisch: Standard 3σ/4σ.',functional:'Funktional: Cpk ≥ 1.33, > 4σ.',safety:'Sicherheit: Worst-Case maßgebend.'};
  if(desc) desc.textContent = shortTxt[c]||shortTxt.visual;
  // Falls bereits eine Kette aufgebaut ist: Analyse neu rendern
  if(typeof aiBuiltLinks!=='undefined' && aiBuiltLinks.length){
    const a=(document.getElementById('part-a')||{}).value||'';
    const b=(document.getElementById('part-b')||{}).value||'';
    const host=document.getElementById('builder-result');
    if(host && host.innerHTML.trim()) renderBuilderPreview(a,b,aiBuiltLinks,false);
  }
}
function showReqClassInfo(){
  const d={
    visual:'Optisch: Standard-Bewertung mit 3σ/4σ je nach Einstellung. Fokus auf gleichmäßiges Spalt-/Bündigkeitsbild.',
    functional:'Funktional: < 1 Fehlerfahrzeug gefordert (Ziel > 4σ, Cpk ≥ 1.33). Funktion muss über die Serie sicher erfüllt sein.',
    safety:'Sicherheitsrelevant: Worst-Case < 1 Fehlerfahrzeug. Strengste Bewertung – auch die WC-Spanne muss innerhalb der Vorgabe liegen (Ziel > 6σ).'
  };
  const labels={visual:'👁 Optisch',functional:'⚙ Funktional',safety:'🛡 Sicherheitsrelevant'};
  showInfoTip(labels[reqClass], d[reqClass]||d.visual);
}

// Typische Eigentoleranz-Bandbreiten je Fertigungsart (mm, ±) – für Plausibilitätsprüfung
const TOL_PLAUSIBILITY = {
  'stamping':   {min:0.3, max:1.5, label:'Tiefziehen/Pressteil'},
  'welding':    {min:0.5, max:2.5, label:'Schweißbaugruppe'},
  'injection':  {min:0.2, max:1.0, label:'Spritzguss'},
  'casting':    {min:0.1, max:0.6, label:'Druckguss/Scharnier'},
  'assembly':   {min:0.2, max:0.8, label:'Montage/Anbau'},
  'machining':  {min:0.05, max:0.3, label:'Zerspanung'},
};
// Grobe Fahrzeug-Region je Bauteil (für sinnvolle Paar-Prüfung)
function partRegion(name){
  const z=getPartZone(name);
  if(!z||z.x<0) return null;
  if(z.x<33) return 'front';
  if(z.x<66) return 'side';
  return 'rear';
}

// Schätzt Fehlerfahrzeuge aus Cpk + Stückzahl
function estimateDefectVehicles(cpk, qty){
  if(!qty||qty<=0) return null;
  // PPM aus Cpk (zentriert, mit 1.5σ-Shift wie üblich in der Serie)
  const z = cpk*3 - 1.5;
  const ppm = normCDF(-z)*1e6;
  return {ppm, vehicles: ppm/1e6*qty};
}

// ── KONFORMITÄTSWAHRUNG: Verteilungsannahme & Zentraler Grenzwertsatz (ZGS/CLT) ──
// Prüft, ob die RSS-Voraussetzungen (Normalverteilung via ZGS) gewahrt sind.
// Liefert Befunde + recherchierte Handlungsempfehlungen.
function checkConformity(chainLinks){
  const out=[]; // {level, icon, title, text, actions:[]}
  // Montage-Schnittstellen sind reale Streuquellen → bei ZGS/Konformität mitzählen
  const real = chainLinks.slice();
  const n = real.length;
  const depth = levelDepth();

  // Varianzbeiträge für Dominanz-Prüfung
  const vars = real.map(l=>Math.pow((l.upper-l.lower)/2*(l.distributionFactor||1),2));
  const totalVar = vars.reduce((a,v)=>a+v,0);
  const maxShare = totalVar>0 ? Math.max(...vars)/totalVar : 0;
  const domIdx = vars.indexOf(Math.max(...vars));
  const domName = real[domIdx] ? real[domIdx].name : '';

  // 1) Anzahl Beitragsleister (ZGS braucht „genügend" unabhängige Beiträge)
  if(n < 3){
    out.push({level:'error',icon:'⛔',
      title:'ZGS nicht gewahrt – zu wenige Beitragsleister',
      text: depth>=1
        ? `Nur ${n} Beitragsleister. Der Zentrale Grenzwertsatz greift erst bei mehreren unabhängigen, ähnlich großen Beiträgen – die Summe ist hier nicht zuverlässig normalverteilt. Die RSS-Annahme (Gauß) ist unsicher.`
        : `Nur ${n} Beitragsleister – RSS/Gauß-Annahme unsicher.`,
      actions:[
        'Worst-Case-Bewertung als Absicherung heranziehen (konservativ).',
        'Monte-Carlo-Simulation statt RSS verwenden (Tab „Monte Carlo").',
        depth>=1?'MRSS-Korrekturfaktor (1,4–1,8 × RSS) ansetzen, um die optimistische RSS-Schätzung zu entschärfen.':null,
      ].filter(Boolean)});
  } else if(n < 5){
    out.push({level:'warn',icon:'⚠',
      title:'ZGS schwach – wenige Beitragsleister',
      text: depth>=1
        ? `${n} Beitragsleister. Die Fachliteratur sieht ~5+ unabhängige Beiträge als Richtwert; darunter ist die Konvergenz zur Normalverteilung schwach und RSS tendenziell optimistisch.`
        : `${n} Beitragsleister – ZGS-Konvergenz schwach.`,
      actions:[
        'Ergebnis mit Worst-Case gegenprüfen.',
        depth>=1?'Monte-Carlo zur Verteilungsprüfung nutzen.':null,
        depth>=2?'MRSS-Faktor nach Drake (Dimensioning and Tolerancing Handbook) erwägen.':null,
      ].filter(Boolean)});
  }

  // 2) Dominanter Einzelbeitrag bricht den ZGS
  if(maxShare > 0.6 && n>=2){
    out.push({level:'warn',icon:'⚠',
      title:'Dominanter Einzelbeitrag',
      text: depth>=1
        ? `„${domName}" trägt ${(maxShare*100).toFixed(0)}% der Gesamtvarianz. Dominiert ein einzelner Term, nähert sich die Summe NICHT der Normalverteilung an – die Verteilung folgt im Wesentlichen diesem einen Beitrag. Die Gauß-Annahme ist dann nicht begründet.`
        : `„${domName}" dominiert mit ${(maxShare*100).toFixed(0)}% – Gauß-Annahme fraglich.`,
      actions:[
        `Verteilung von „${domName}" prüfen: Ist dieser Beitrag selbst normalverteilt?`,
        'Diesen Beitragsleister gezielt reduzieren – verbessert Konformität UND Gesamttoleranz.',
        depth>=1?'Bei nicht-normalem Hauptbeitrag: Monte-Carlo mit der realen Verteilung rechnen.':null,
      ].filter(Boolean)});
  }

  // 3) Verteilungsannahme je Beitrag hinterfragen (Prozesse, die typ. nicht-normal sind)
  // Passungen/HLM (distributionFactor≠1) und bestimmte Prozesse sind oft nicht-normal.
  const nonNormalHints = real.filter(l=>{
    return (l.distributionFactor && Math.abs(l.distributionFactor-1)>0.01) // Gleichverteilung angenommen
        || /lager|passung|spiel|hole|pin|gleit/i.test(l.name||'');
  });
  if(nonNormalHints.length && depth>=1){
    out.push({level:'info',icon:'ℹ',
      title:'Verteilungsannahme hinterfragen',
      text:`${nonNormalHints.length} Beitrag/Beiträge (z.B. „${nonNormalHints[0].name}") werden nicht als Normalverteilung, sondern mit abweichendem Verteilungsfaktor geführt. Solche Prozesse (Passungen, Spiele, einseitig begrenzte Maße) sind oft asymmetrisch oder gleichverteilt.`,
      actions:[
        'Reale Prozessverteilung aus Messdaten/SPC bestätigen (Cp/Cpk-Tab mit Messwerten).',
        depth>=2?'Bei Asymmetrie: Monte-Carlo mit passender Verteilung (Dreieck, Gleichverteilung) statt Gauß.':null,
        depth>=2?'Quelle: nicht alle Fertigungsprozesse folgen der Normalverteilung – RSS dann nur eingeschränkt gültig (fiveflute, eng-tips Community).':null,
      ].filter(Boolean)});
  }

  // 4) Konformität gewahrt (positiver Befund)
  if(!out.length){
    out.push({level:'ok',icon:'✓',
      title:'Konformität gewahrt',
      text: depth>=1
        ? `${n} unabhängige Beitragsleister, kein dominanter Einzelterm (max. ${(maxShare*100).toFixed(0)}%). Der Zentrale Grenzwertsatz stützt die Normalverteilungsannahme – die RSS-/Gauß-Bewertung ist begründet.`
        : `ZGS gewahrt – RSS/Gauß begründet.`,
      actions:[]});
  }
  return out;
}

// HAUPTFUNKTION: analysiert die Kette und gibt Befunde + Vorschläge zurück
function analyzeChain(partA, partB, chainLinks, spec){
  const findings = []; // {level:'ok'|'info'|'warn'|'error', icon, title, text}
  const rss3 = Math.sqrt(chainLinks.reduce((a,l)=>a+Math.pow((l.upper-l.lower)/2*(l.distributionFactor||1),2),0));
  const rssHalf4 = rss3*4/3; // ±4σ Halbspanne
  const wcHalf = chainLinks.reduce((a,l)=>a+(l.upper-l.lower)/2,0);
  const specTol = spec && spec.tol>0 ? spec.tol : null;

  // ── 1) ANFORDERUNGSKLASSE: Bewertung gegen Vorgabe ──
  let classVerdict=null;
  if(specTol){
    if(reqClass==='safety'){
      const ok = wcHalf <= specTol;
      classVerdict = {
        ok,
        level: ok?'ok':'error',
        title: ok?'Sicherheitsanforderung erfüllt':'Sicherheitsanforderung NICHT erfüllt',
        text: ok
          ? `Worst-Case-Spanne ±${wcHalf.toFixed(1)}mm liegt innerhalb der Vorgabe ±${specTol.toFixed(1)}mm. Selbst im ungünstigsten Fall entsteht < 1 Fehlerfahrzeug.`
          : `Worst-Case ±${wcHalf.toFixed(1)}mm überschreitet die Vorgabe ±${specTol.toFixed(1)}mm. Für sicherheitsrelevante Maße muss auch der Worst-Case eingehalten werden.`
      };
    } else if(reqClass==='functional'){
      const cpk = rss3>0 ? specTol/rss3 : 99; // rss3=±3σ-Halbspanne → σ=rss3/3 → Cpk=specTol/(3σ)=specTol/rss3
      const ok = cpk>=1.33;
      classVerdict = {
        ok,
        level: ok?'ok':(cpk>=1.0?'warn':'error'),
        title: `Funktional: Cpk ≈ ${cpk.toFixed(2)} (${(cpk*3).toFixed(1)}σ)`,
        text: ok
          ? `Statistische Lage erfüllt > 4σ (< 1 Fehlerfahrzeug). RSS ±${rss3.toFixed(1)}mm passt zur Vorgabe ±${specTol.toFixed(1)}mm.`
          : `Cpk ${cpk.toFixed(2)} unter Ziel 1.33. RSS ±${rss3.toFixed(1)}mm ist für die Vorgabe ±${specTol.toFixed(1)}mm zu groß – Toleranzen reduzieren.`
      };
    } else { // visual
      const half = sigmaMode===4 ? rssHalf4 : rss3;
      const ok = half <= specTol;
      classVerdict = {
        ok,
        level: ok?'ok':'warn',
        title: ok?`Optisch i.O. (±${half.toFixed(1)}mm bei ${sigmaMode}σ)`:`Optisch grenzwertig (±${half.toFixed(1)}mm bei ${sigmaMode}σ)`,
        text: ok
          ? `Statistische Schließmaßtoleranz hält die Vorgabe ±${specTol.toFixed(1)}mm bei ${sigmaMode}σ ein – gleichmäßiges Spaltbild erwartbar.`
          : `Bei ${sigmaMode}σ ergibt sich ±${half.toFixed(1)}mm > Vorgabe ±${specTol.toFixed(1)}mm. Optisch kann das Spaltbild ungleichmäßig wirken.`
      };
    }
  }

  // ── 2) PLAUSIBILITÄT: unplausible Einzeltoleranzen ──
  chainLinks.forEach(l=>{
    // Montage zählt mit (assembly-Band); nur reine Strukturzusammenfassung 'Karosserie' ausnehmen
    const band = TOL_PLAUSIBILITY[l.mfg];
    if(!band) return;
    const tol = (l.upper-l.lower)/2;
    if(tol > band.max*1.5){
      findings.push({level:'warn',icon:'⚠',title:`Hohe Toleranz: ${l.name}`,
        text:`±${tol.toFixed(1)}mm ist für ${band.label} ungewöhnlich groß (typisch ±${band.min}–${band.max}mm). Bitte Wert prüfen.`});
    } else if(tol < band.min*0.5 && tol>0){
      findings.push({level:'info',icon:'ℹ',title:`Sehr enge Toleranz: ${l.name}`,
        text:`±${tol.toFixed(1)}mm ist für ${band.label} sehr eng (typisch ±${band.min}–${band.max}mm) – ggf. fertigungstechnisch teuer.`});
    }
  });

  // ── 3) PLAUSIBILITÄT: unsinniges Bauteilpaar ──
  const rA=partRegion(partA), rB=partRegion(partB);
  if(rA && rB){
    const opposite = (rA==='front'&&rB==='rear')||(rA==='rear'&&rB==='front');
    if(opposite){
      findings.push({level:'warn',icon:'⚠',title:'Bauteilpaar prüfen',
        text:`„${partA}" (Front) und „${partB}" (Heck) liegen an entgegengesetzten Fahrzeugenden. Ein direktes Schließmaß dazwischen ist untypisch – ist die Paarung korrekt?`});
    }
  }

  // ── 4) PLAUSIBILITÄT: unplausible Toleranzvorgabe ──
  if(specTol){
    if(specTol > wcHalf){
      findings.push({level:'info',icon:'ℹ',title:'Vorgabe großzügig',
        text:`Die Vorgabe ±${specTol.toFixed(1)}mm ist größer als der Worst-Case ±${wcHalf.toFixed(1)}mm der Kette – sie wird immer eingehalten. Ggf. enger spezifizieren.`});
    }
    if(specTol < rss3*0.5){
      const g=findGapReference(partA,partB);
      const isRecommended = g && Math.abs(specTol-g.tol)<0.05;
      findings.push({level:'warn',icon:'⚠',title:'Ziel mit aktueller Kette nicht erreicht',
        text:`Das ${isRecommended?'empfohlene ':''}Ziel ±${specTol.toFixed(1)}mm ist enger als das, was die aktuelle Kette liefert (RSS ±${rss3.toFixed(1)}mm). Das Ziel ist sinnvoll – aber die ${chainLinks.length>0?chainLinks.length+'-gliedrige ':''}Kette streut zu stark. Lösung: Einzeltoleranzen straffen (siehe Toleranz-Allokation) oder Kette kürzen. Faktor ${(rss3/specTol).toFixed(1)}× zu groß.`});
    }
    if(spec.nom && spec.nom>0){
      const g=findGapReference(partA,partB);
      if(g && Math.abs(spec.nom-g.gap)>g.gap*0.6){
        findings.push({level:'info',icon:'ℹ',title:'Nennmaß ungewöhnlich',
          text:`Nennmaß ${spec.nom}mm weicht deutlich vom typischen ${g.gap}mm (${g.note}) ab. Bitte prüfen.`});
      }
    }
  }

  // ── 5) TOLERANZVORSCHLÄGE: nach Beitrags-Analyse ──
  const suggestions = [];
  // Ziel-RSS je Anforderungsklasse: visual = specTol (bei gewähltem σ), funktional = specTol/1.33, safety = specTol/2 (≈6σ)
  const cpkTarget = reqClass==='safety' ? 1.67 : (reqClass==='functional' ? 1.33 : 1.0);
  const targetRss = reqClass==='visual'
      ? (sigmaMode===4 ? specTol*3/4 : specTol)   // bei 4σ ist rss3 = specTol·3/4
      : specTol/cpkTarget;
  if(specTol && rss3 > targetRss*1.001){
    const totalVar = chainLinks.reduce((a,l)=>a+Math.pow((l.upper-l.lower)/2*(l.distributionFactor||1),2),0);
    const sorted = chainLinks.map(l=>({
      name:l.name, mfg:l.mfg, type:l.type,
      tol:(l.upper-l.lower)/2,
      varShare: totalVar>0?Math.pow((l.upper-l.lower)/2*(l.distributionFactor||1),2)/totalVar:0
    })).sort((a,b)=>b.varShare-a.varShare);
    const reduceFactor = targetRss/rss3;
    suggestions.push({
      headline:`RSS ±${rss3.toFixed(1)}mm muss auf ±${targetRss.toFixed(1)}mm sinken (Faktor ${reduceFactor.toFixed(2)}×, Ziel ${reqClass==='visual'?sigmaMode+'σ':'Cpk '+cpkTarget})`,
      items: sorted.slice(0,3).map(s=>{
        const newTol = s.tol*reduceFactor;
        const band = TOL_PLAUSIBILITY[s.mfg];
        const feasible = !band || newTol>=band.min;
        return {
          name:s.name,
          text:`${(s.varShare*100).toFixed(0)}% Varianzbeitrag · ±${s.tol.toFixed(1)} → ±${newTol.toFixed(1)}mm`,
          warn: !feasible ? `unter Fertigungsgrenze (±${band.min}mm) – Konstruktion/Prozess ändern` : null
        };
      })
    });
  } else if(specTol){
    suggestions.push({headline:`Kette erfüllt die Vorgabe – RSS ±${rss3.toFixed(1)}mm ≤ Ziel ±${targetRss.toFixed(1)}mm`, items:[]});
  }

  // ── Fehlerfahrzeuge (wenn Stückzahl + Vorgabe vorhanden) ──
  let defectInfo=null;
  if(specTol){
    const cpk = rss3>0 ? specTol/rss3 : 99; // rss3=±3σ-Halbspanne → σ=rss3/3 → Cpk=specTol/(3σ)=specTol/rss3
    const qty = (typeof getEffectiveQty==='function') ? getEffectiveQty() : null;
    const est = estimateDefectVehicles(cpk, qty);
    if(est) defectInfo={cpk, ppm:est.ppm, vehicles:est.vehicles, qty};
  }

  return {classVerdict, findings, suggestions, defectInfo, rss3, wcHalf, conformity: checkConformity(chainLinks)};
}

// Rendert die Analyse als Karten-HTML
function renderAnalysis(partA, partB, chainLinks){
  const spec = chainSpec || (()=>{
    const nom=parseFloat((document.getElementById('spec-nom')||{}).value);
    const tol=parseFloat((document.getElementById('spec-tol')||{}).value);
    const cpk=parseFloat((document.getElementById('spec-cpk')||{}).value);
    return (!isNaN(tol)&&tol>0)?{nom:isNaN(nom)?0:nom,tol,cpk:isNaN(cpk)?1.33:cpk}:null;
  })();
  const a = analyzeChain(partA, partB, chainLinks, spec);
  const lvlColor={ok:'#1DAA6A',info:'#1A6FD4',warn:'#F5A623',error:'#D93025'};
  const lvlBg={ok:'rgba(29,170,106,.08)',info:'var(--blue-light)',warn:'#FFF8E8',error:'rgba(217,48,37,.08)'};

  let html=`<div class="card"><div class="card-title">
    <svg viewBox="0 0 24 24" fill="none"><path d="M12 2L13.5 8.5L20 7L15.5 12L20 17L13.5 15.5L12 22L10.5 15.5L4 17L8.5 12L4 7L10.5 8.5L12 2Z" fill="currentColor" opacity=".85"/></svg>
    Analyse & Bewertung</div>`;

  // Klassen-Badge + Merkmal/Bewertungs-Badge
  const classLabels={visual:'👁 Optisch',functional:'⚙ Funktional',safety:'🛡 Sicherheitsrelevant'};
  const featLabels={gap:'↔ Spalt',flush:'⇕ Versatz'};
  const evalLabels={dimension:'Maß',parallel:'∥ Parallelität',symmetry:'⊜ Symmetrie',uniform:'≈ Gleichmäßigkeit'};
  html+=`<div style="display:flex;flex-wrap:wrap;gap:6px;margin-bottom:12px">
    <span style="display:inline-flex;align-items:center;gap:5px;font-size:13px;font-weight:600;padding:4px 10px;border-radius:8px;background:var(--surface2);border:1px solid var(--border)">${classLabels[reqClass]}</span>
    <span style="display:inline-flex;align-items:center;gap:5px;font-size:13px;font-weight:600;padding:4px 10px;border-radius:8px;background:var(--blue-light);color:var(--blue)">${featLabels[featType]}</span>
    ${evalType!=='dimension'?`<span style="display:inline-flex;align-items:center;gap:5px;font-size:13px;font-weight:600;padding:4px 10px;border-radius:8px;background:rgba(29,170,106,.1);color:var(--green)">${evalLabels[evalType]}</span>`:''}
  </div>`;

  // Bewertungsmerkmal-spezifischer Hinweis (Parallelität/Symmetrie/Gleichmäßigkeit)
  if(spec && evalType!=='dimension'){
    // ── Zwei-Schließmaß-Bewertung als EINSEITIGE SPANNE Δ (kein ±, GD&T-/Spaltbild-Praxis) ──
    // Differenz Δ = Spalt1 − Spalt2. Beide Punkte aus derselben Kette → σ_Δ = σ·√2.
    // Die DIFFERENZ schwankt um 0; die zulässige Zone ist die volle Spanne (beidseitig um 0).
    // Maßtoleranz T (±-Halbspanne) entspricht 3σ bzw. 4σ je Modus. Spanne der Differenz = 2·T·√2.
    const rss3 = a.rss3;                         // ±3σ-Halbspanne EINES Schließmaßes
    const tHalf = sigmaMode===4 ? rss3*4/3 : rss3; // ±-Halbspanne im gewählten σ-Modus
    const deltaSpan = 2 * tHalf * Math.SQRT2;    // einseitige Gesamt-Spanne der Differenz (kein ±)
    const specDelta = spec.tol;                  // Vorgabe ist bereits einseitige Δ-Spanne (kein ±)
    const ok = deltaSpan <= specDelta;
    const depth = levelDepth();

    const headline = {
      parallel:'Parallelität – Differenz zweier Schließmaße',
      symmetry:'Symmetrie – Vergleich linkes/rechtes Schließmaß',
      uniform:'Gleichmäßigkeit – Streuung über die Fuge'
    }[evalType];
    const defn = {
      parallel:'Keilfehler Δ = |Spalt₁ − Spalt₂| (Fugenanfang ↔ -ende)',
      symmetry:'Symmetriefehler Δ = |Spalt_links − Spalt_rechts|',
      uniform:'Spannweite R = Spalt_max − Spalt_min über die Messpunkte'
    }[evalType];
    const formula = `${defn}. Beide Punkte aus derselben Kette → Δ-Spanne = 2·T·√2 = 2·${tHalf.toFixed(1)}·√2 = <strong>${deltaSpan.toFixed(1)} mm</strong> (${sigmaMode}σ, einseitig ohne ±).`;
    const verdictTxt = ok
      ? `Erreichbare ${evalType==='uniform'?'Spannweite R':'Differenz Δ'} ${deltaSpan.toFixed(1)} mm hält die Vorgabe ${specDelta.toFixed(1)} mm ein.`
      : `Erreichbare ${evalType==='uniform'?'Spannweite R':'Differenz Δ'} ${deltaSpan.toFixed(1)} mm überschreitet die Vorgabe ${specDelta.toFixed(1)} mm – Streuung der Kette reduzieren oder gemeinsame Bezüge (Karosserie) stärken.`;
    const col = ok ? '#1DAA6A' : '#D93025';
    html+=`<div style="background:${ok?'rgba(29,170,106,.06)':'rgba(217,48,37,.06)'};border:1px solid ${col}33;border-left:3px solid ${col};border-radius:8px;padding:10px 12px;margin-bottom:10px">
      <div style="font-size:13px;font-weight:700;color:${col};margin-bottom:4px">${ok?'✓':'!'} ${evalLabels[evalType]} – ${headline}</div>
      <div style="font-size:13px;color:var(--text2);line-height:1.55;margin-bottom:5px">${verdictTxt}</div>
      ${depth>=1?`<div style="font-size:12px;color:var(--text3);line-height:1.5;background:var(--surface);border-radius:6px;padding:7px 9px">📐 ${formula}</div>`:''}
      ${depth>=1?`<div style="font-size:11px;color:var(--text3);margin-top:5px">Form-/Lagemerkmal: einseitige Zone ohne Vorzeichen (kein ±). Konservativ ohne Korrelation – teilen beide Punkte Bezüge (gemeinsame Karosserie), ist der reale Fehler kleiner. Norm: ISO 1101 ${evalType==='parallel'?'∥':evalType==='symmetry'?'⊜':'(Profil/Form)'}.</div>`:''}
    </div>`;
  }

  if(!spec){
    html+=`<div style="font-size:13px;color:var(--text3);background:var(--surface2);padding:10px 12px;border-radius:8px;line-height:1.5">💡 Toleranzvorgabe (Soll) oben eingeben, um Anforderungsklasse, Plausibilität und Toleranzvorschläge zu bewerten.</div>`;
  }

  // Klassen-Verdikt
  if(a.classVerdict){
    const v=a.classVerdict;
    html+=`<div style="background:${lvlBg[v.level]};border:1px solid ${lvlColor[v.level]}40;border-left:3px solid ${lvlColor[v.level]};border-radius:8px;padding:10px 12px;margin-bottom:10px">
      <div style="font-size:12px;font-weight:700;color:${lvlColor[v.level]};margin-bottom:3px">${v.ok?'✓':'!'} ${v.title}</div>
      <div style="font-size:13px;color:var(--text2);line-height:1.5">${v.text}</div></div>`;
  }

  // Fehlerfahrzeuge
  if(a.defectInfo){
    const d=a.defectInfo;
    const vehColor = d.vehicles<1?'#1DAA6A':d.vehicles<10?'#F5A623':'#D93025';
    html+=`<div style="display:flex;gap:8px;margin-bottom:10px">
      <div style="flex:1;background:var(--surface2);border-radius:8px;padding:8px;text-align:center">
        <div style="font-size:18px;font-weight:700;font-family:'JetBrains Mono',monospace;color:${vehColor}">${d.vehicles<1?'< 1':Math.round(d.vehicles)}</div>
        <div style="font-size:11px;color:var(--text3)">Fehlerfahrzeuge${d.qty?` / ${d.qty.toLocaleString('de-DE')}`:''}</div>
      </div>
      <div style="flex:1;background:var(--surface2);border-radius:8px;padding:8px;text-align:center">
        <div style="font-size:18px;font-weight:700;font-family:'JetBrains Mono',monospace;color:var(--text2)">${d.ppm<1?'< 1':Math.round(d.ppm).toLocaleString('de-DE')}</div>
        <div style="font-size:11px;color:var(--text3)">PPM (mit 1.5σ-Shift)</div>
      </div>
      <div style="flex:1;background:var(--surface2);border-radius:8px;padding:8px;text-align:center">
        <div style="font-size:18px;font-weight:700;font-family:'JetBrains Mono',monospace;color:${capColor?capColor(d.cpk):'var(--text2)'}">${d.cpk>9?'≫':d.cpk.toFixed(2)}</div>
        <div style="font-size:11px;color:var(--text3)">Cpk (Soll/RSS)</div>
      </div>
    </div>`;
  }

  // Plausibilitäts-Befunde
  if(a.findings.length){
    html+=`<div style="font-size:13px;font-weight:600;color:var(--text2);margin:10px 0 6px">Plausibilitätsprüfung</div>`;
    a.findings.forEach(f=>{
      html+=`<div style="display:flex;gap:8px;background:${lvlBg[f.level]};border-radius:7px;padding:8px 10px;margin-bottom:6px">
        <span style="font-size:14px;flex-shrink:0">${f.icon}</span>
        <div><div style="font-size:13px;font-weight:600;color:${lvlColor[f.level]}">${f.title}</div>
        <div style="font-size:13px;color:var(--text2);line-height:1.45;margin-top:1px">${f.text}</div></div></div>`;
    });
  } else if(spec && levelDepth()>=1){
    html+=`<div style="font-size:13px;color:#1DAA6A;background:rgba(29,170,106,.08);padding:8px 10px;border-radius:7px;margin-bottom:6px">✓ Keine Plausibilitäts-Auffälligkeiten bei Toleranzen und Bauteilpaar.</div>`;
  }

  // Konformitätswahrung (Verteilung / ZGS) — nur bei Problemen zeigen, nie bei reinem ok
  if(a.conformity && a.conformity.some(c=>c.level!=='ok')){
    const depth=levelDepth();
    const confShow = a.conformity.filter(c=>c.level!=='ok');
    if(confShow.length){
      html+=`<div style="font-size:13px;font-weight:600;color:var(--text2);margin:10px 0 6px">🔬 Konformitätswahrung (Verteilung & ZGS)</div>`;
      confShow.forEach(c=>{
      html+=`<div style="display:flex;gap:8px;background:${lvlBg[c.level]};border-radius:7px;padding:8px 10px;margin-bottom:6px">
        <span style="font-size:14px;flex-shrink:0">${c.icon}</span>
        <div style="flex:1"><div style="font-size:13px;font-weight:600;color:${lvlColor[c.level]}">${c.title}</div>
        <div style="font-size:13px;color:var(--text2);line-height:1.45;margin-top:1px">${c.text}</div>
        ${(c.actions&&c.actions.length&&depth>=1)?`<div style="margin-top:6px">
          <div style="font-size:12px;font-weight:600;color:var(--text3);margin-bottom:2px">Handlungsempfehlungen:</div>
          ${c.actions.map(ac=>`<div style="font-size:12px;color:var(--text2);line-height:1.45;padding-left:10px;position:relative"><span style="position:absolute;left:0">›</span>${ac}</div>`).join('')}
        </div>`:''}
        </div></div>`;
    });
    }
  }

  // Toleranzvorschläge
  if(a.suggestions.length){
    a.suggestions.forEach(sg=>{
      html+=`<div style="font-size:13px;font-weight:600;color:var(--text2);margin:10px 0 6px">💡 Toleranzvorschlag</div>
        <div style="font-size:13px;color:var(--text2);background:var(--blue-light);padding:8px 10px;border-radius:7px;line-height:1.5;margin-bottom:${sg.items.length?'6px':'0'}">${sg.headline}</div>`;
      sg.items.forEach(it=>{
        html+=`<div style="display:flex;gap:8px;align-items:flex-start;padding:6px 10px;margin-bottom:4px;border:1px solid var(--border);border-radius:7px">
          <div style="flex:1"><div style="font-size:13px;font-weight:600;color:var(--text2)">${it.name}</div>
          <div style="font-size:12px;color:var(--text3);font-family:'JetBrains Mono',monospace">${it.text}</div>
          ${it.warn?`<div style="font-size:12px;color:#D93025;margin-top:2px">⛔ ${it.warn}</div>`:''}</div></div>`;
      });
    });
  }

  html+=`</div>`;
  return html;
}

