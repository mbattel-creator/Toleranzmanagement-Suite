      <div class="card-title"><svg viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="4" height="4" rx="1" fill="currentColor"/><rect x="17" y="3" width="4" height="4" rx="1" fill="currentColor"/><rect x="10" y="10" width="4" height="4" rx="1" fill="currentColor"/></svg>${runs.toLocaleString('de')} Simulationen</div>
      <div style="display:flex;align-items:flex-end;gap:2px;height:80px;margin-bottom:6px">
        ${counts.map((c,i)=>{const xc=hmin+(i+0.5)*bw;const out=defLimit!=null&&(xc>defLimit||xc<-defLimit);return `<div class="hist-bar"><div class="hist-fill" style="height:${Math.round(c/maxC*72)}px;background:${out?'#D93025':'#1A6FD4'};opacity:${(0.45+c/maxC*0.55).toFixed(2)}"></div></div>`;}).join('')}
      </div>
      <div style="display:flex;justify-content:space-between;font-size:12px;color:var(--text3);margin-bottom:12px"><span>${fmt(hmin,3)}</span><span>Abweichung (mm)</span><span>${fmt(hmax,3)}</span></div>
      <div class="row2">
        <div class="metric"><div class="metric-val" style="color:var(--blue);font-size:18px">${fmt(mean,4)}</div><div class="metric-lbl">Mittelwert</div></div>
        <div class="metric"><div class="metric-val" style="color:var(--blue);font-size:18px">${fmt(s,4)}</div><div class="metric-lbl">Std.abw.</div></div>
      </div>
    </div>
    ${chainSpec ? renderMCSpecCard(s, mean) : `<div class="card" style="background:var(--surface2)"><div style="font-size:13px;color:var(--text3);text-align:center">💡 Toleranzvorgabe im KI-Tab (Ketten-Builder) setzen für Soll/Ist-Bewertung</div></div>`}
    ${defLimit!=null ? renderQualityCard(defectCount, defectPct, ppm, n2, qty, errorVehicles) : `<div class="card" style="background:var(--surface2)"><div style="font-size:13px;color:var(--text3);text-align:center">💡 Zieltoleranz oder Toleranzvorgabe setzen für DPMO/PPM & Fehlerfahrzeuge</div></div>`}
    <div class="card">
      <div class="card-title"><svg viewBox="0 0 24 24" fill="none"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2" stroke="currentColor" stroke-linecap="round"/></svg>Konfidenzintervalle</div>
      <div class="stat-row"><span class="stat-lbl">95% Intervall</span><span class="stat-val">${fmt(p025,3)} … ${fmt(p975,3)}</span></div>
      <div class="stat-row"><span class="stat-lbl">Median</span><span class="stat-val">${fmt(p50,4)}</span></div>
      ${defLimit!=null?`<div class="stat-row"><span class="stat-lbl">Fehlergrenze ±</span><span class="stat-val">${fmt(defLimit,3)} mm ${hasTarget?'(Ziel)':'(Vorgabe)'}</span></div>`:''}
