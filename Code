function loadValuesFromFile(event, targetId, countId){
  const file = event.target.files[0];
  if(!file) return;
  const reader = new FileReader();
  reader.onload = function(e){
    let text = e.target.result;
    // Alle Zahlen extrahieren (egal ob CSV, TSV, zeilenweise, mit Header)
    const nums = text.split(/[,;\n\r\t ]+/)
      .map(v=>parseFloat(String(v).trim().replace(',','.')))
      .filter(v=>!isNaN(v));
    if(!nums.length){
      toast('Keine gültigen Messwerte in der Datei gefunden.','error');
      return;
    }
    document.getElementById(targetId).value = nums.join(', ');
    document.getElementById(countId).textContent = nums.length+' Werte erkannt';
  };
  reader.onerror = ()=>toast('Datei konnte nicht gelesen werden.','error');
  reader.readAsText(file);
  event.target.value = ''; // erlaubt erneutes Laden derselben Datei
}
function capColor(v){return v>=1.67?'#1DAA6A':v>=1.33?'#3CB371':v>=1.0?'#F5A623':'#D93025';}
function normCDF(x){const t=1/(1+0.2316419*Math.abs(x)),d=0.3989422820*Math.exp(-x*x/2),p=d*t*(0.3193815+t*(-0.3565638+t*(1.7814779+t*(-1.8212560+t*1.3302744))));return x>0?1-p:p;}
function perc(s,p){const i=p*(s.length-1),lo=Math.floor(i),hi=Math.min(lo+1,s.length-1);return s[lo]*(1-(i-lo))+s[hi]*(i-lo);}

