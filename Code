// (PART_SYNONYMS wird im Fahrzeug-Modul deklariert)
let activeSuggestField = null;
function getAllPartNames(){
  // alle DB-Namen, dedupliziert
  if(!window._partNames){
    window._partNames = [...new Set(PARTS_DB.map(p=>p[0]))];
  }
  return window._partNames;
}
function scorePart(query, name){
  const q=query.toLowerCase().trim(), n=name.toLowerCase();
  if(!q) return 0;
  if(n===q) return 100;
  if(n.startsWith(q)) return 80;
  if(n.includes(q)) return 60;
  // Wortweise
  const qw=q.split(/\s+/);
  let hits=qw.filter(w=>w.length>=2 && n.includes(w)).length;
  if(hits) return 30+hits*5;
  return 0;
}
function buildSuggestions(query){
  const q=query.toLowerCase().trim();
  let results=[];
  // 1) Synonym-Treffer (Kontext): wenn Query einem Synonym entspricht
  const synKey=Object.keys(PART_SYNONYMS).find(k=>q===k || q.includes(k) || k.includes(q));
  if(synKey){
    PART_SYNONYMS[synKey].forEach(name=>{
      const p=PARTS_DB.find(x=>x[0]===name);
      if(p) results.push({name, cat:p[1], hint:'Vorschlag', score:90});
    });
  }
  // 2) Direkte Namens-Treffer
  getAllPartNames().forEach(name=>{
    const s=scorePart(query,name);
    if(s>0 && !results.find(r=>r.name===name)){
      const p=PARTS_DB.find(x=>x[0]===name);
      results.push({name, cat:p?p[1]:'', hint:'', score:s});
    }
  });
  results.sort((a,b)=>b.score-a.score);
  return results.slice(0,8);
}
function onPartInput(field){
  activeSuggestField=field;
  const inp=document.getElementById('part-'+field);
  const box=document.getElementById('suggest-'+field);
  const q=inp.value;
  const sugg = q.trim()==='' ? topPartSuggestions() : buildSuggestions(q);
  if(!sugg.length){
    box.innerHTML=`<div class="part-suggest-empty">${LANG==='en'?'No match – free text is kept. Set marker manually if needed.':'Kein Treffer – Freitext wird übernommen. Markierung ggf. manuell setzen.'}</div>`;
    box.classList.remove('hidden');
    return;
  }
  box.innerHTML=sugg.map(s=>`<div class="part-suggest-item" onmousedown="pickPart('${field}','${s.name.replace(/'/g,"\\'")}')">
    <span class="ps-name">${s.name}</span>
    <span class="ps-cat">${s.cat}${s.hint?` · <span class="ps-hint">${s.hint}</span>`:''}</span>
  </div>`).join('');
  box.classList.remove('hidden');
}
