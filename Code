let paretoRows = [{cause:'',count:''},{cause:'',count:''},{cause:'',count:''}];
function renderParetoInputs(){
  document.getElementById('pareto-inputs').innerHTML = paretoRows.map((r,i)=>`
    <div style="display:flex;gap:8px;margin-bottom:8px;align-items:center">
      <input type="text" placeholder="Ursache ${i+1}" value="${r.cause}" oninput="paretoRows[${i}].cause=this.value" style="flex:2;font-family:'Inter',sans-serif">
