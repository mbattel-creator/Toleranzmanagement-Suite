function renderSpecEvaluation(rssSpan, wcSpan){
  const specTol = parseFloat(document.getElementById('spec-tol').value);
  const specCpk = parseFloat(document.getElementById('spec-cpk').value) || 1.33;
  if(isNaN(specTol) || specTol <= 0){
    return `<div style="margin-top:12px;font-size:13px;color:var(--text3);background:var(--surface2);padding:10px 12px;border-radius:8px;border:1px dashed var(--border);text-align:center">💡 Trage oben eine ±Toleranzvorgabe ein für die Soll/Ist-Bewertung</div>`;
  }

  // RSS-Halbspanne = Ist-Toleranz (3σ). Vorgabe = Soll.
  const istTol = rssSpan / 2;
  const wcTol = wcSpan / 2;
  // Ausnutzung: Ist / Soll
  const utilRSS = (istTol / specTol) * 100;
  const utilWC = (wcTol / specTol) * 100;

  // Cpk-Schätzung: Cpk = Toleranzvorgabe / (3σ). RSS-Spanne entspricht 6σ → σ = rssSpan/6
  const sigma = rssSpan / 6;
  const cpkEst = sigma > 0 ? specTol / (3 * sigma) : 99;

  // Ampel: grün wenn RSS in Vorgabe UND Cpk-Ziel erreicht, gelb wenn knapp, rot wenn drüber
  let ampel, ampelColor, ampelText, ampelIcon;
  if(utilRSS <= 100 && cpkEst >= specCpk){
    ampel='grün'; ampelColor='#1DAA6A'; ampelText='Vorgabe erfüllt'; ampelIcon='M5 12l5 5L19 7';
  } else if(utilRSS <= 100 && cpkEst >= specCpk * 0.9){
    ampel='gelb'; ampelColor='#F5A623'; ampelText='Grenzwertig – Cpk knapp'; ampelIcon='M12 9v4M12 17h.01';
  } else if(utilRSS <= 110){
    ampel='gelb'; ampelColor='#F5A623'; ampelText='Grenzwertig – Toleranz fast ausgeschöpft'; ampelIcon='M12 9v4M12 17h.01';
  } else {
    ampel='rot'; ampelColor='#D93025'; ampelText='Vorgabe nicht erfüllt'; ampelIcon='M18 6L6 18M6 6l12 12';
  }

  return `
    <div style="margin-top:14px;border:2px solid ${ampelColor};border-radius:var(--radius);overflow:hidden">
      <div style="background:${ampelColor};padding:10px 14px;display:flex;align-items:center;gap:10px">
        <svg viewBox="0 0 24 24" fill="none" style="width:20px;height:20px;stroke:#fff;stroke-width:2.4"><path d="${ampelIcon}" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <span style="color:#fff;font-weight:700;font-size:14px">${ampelText}</span>
        <span style="margin-left:auto;color:#fff;font-size:13px;font-weight:600;text-transform:uppercase;letter-spacing:.5px">${ampel}</span>
      </div>
      <div style="padding:14px;background:var(--surface)">
        <div class="row2" style="margin-bottom:12px">
          <div class="metric" style="background:${utilRSS<=100?'#1DAA6A':'#D93025'}12">
            <div class="metric-val" style="color:${utilRSS<=100?'#1DAA6A':'#D93025'};font-size:18px">${utilRSS.toFixed(0)}%</div>
            <div class="metric-lbl">Ausnutzung RSS</div>
          </div>
          <div class="metric" style="background:${cpkEst>=specCpk?'#1DAA6A':cpkEst>=specCpk*0.9?'#F5A623':'#D93025'}12">
            <div class="metric-val" style="color:${cpkEst>=specCpk?'#1DAA6A':cpkEst>=specCpk*0.9?'#F5A623':'#D93025'};font-size:18px">${cpkEst.toFixed(2)}</div>
            <div class="metric-lbl">Cpk (Schätzung)</div>
          </div>
        </div>

        <div class="stat-row"><span class="stat-lbl">Vorgabe (Soll)</span><span class="stat-val">±${specTol.toFixed(1)} mm</span></div>
        <div class="stat-row"><span class="stat-lbl">Ist statistisch (4σ / 3σ)</span><span class="stat-val" style="color:${utilRSS<=100?'#1DAA6A':'#D93025'}"><strong style="font-size:1.08em">±${(istTol*4/3).toFixed(1)}</strong> <span style="color:var(--text3);font-weight:400">(±${istTol.toFixed(1)})</span> mm</span></div>
        <div class="stat-row"><span class="stat-lbl">Ist Worst-Case</span><span class="stat-val" style="color:${utilWC<=100?'#1DAA6A':'#D93025'}">±${wcTol.toFixed(1)} mm</span></div>
        <div class="stat-row"><span class="stat-lbl">Cpk-Ziel</span><span class="stat-val">${specCpk.toFixed(2)}</span></div>
        <div class="stat-row"><span class="stat-lbl">Reserve (RSS)</span><span class="stat-val" style="color:${specTol-istTol>=0?'#1DAA6A':'#D93025'}">${(specTol-istTol>=0?'+':'')}${(specTol-istTol).toFixed(1)} mm</span></div>

        <!-- Visual bar: Ist vs Soll -->
        <div style="margin-top:12px">
          <div style="font-size:12px;font-weight:600;color:var(--text3);text-transform:uppercase;letter-spacing:.4px;margin-bottom:6px">Ist gegen Vorgabe</div>
          <div style="position:relative;height:24px;background:var(--surface2);border-radius:6px;border:1px solid var(--border);overflow:hidden">
            <!-- Soll marker at 100% -->
            <div style="position:absolute;left:${Math.min(100,100)}%;top:0;bottom:0;width:2px;background:var(--text);z-index:2;transform:translateX(-1px)"></div>
            <!-- RSS fill -->
            <div style="position:absolute;left:0;top:0;bottom:0;width:${Math.min(utilRSS,130)}%;background:${utilRSS<=100?'linear-gradient(90deg,#1DAA6A,#3CB371)':'linear-gradient(90deg,#F5A623,#D93025)'};border-radius:5px 0 0 5px"></div>
          </div>
          <div style="display:flex;justify-content:space-between;font-size:11px;color:var(--text3);margin-top:3px">
            <span>0</span><span style="font-weight:700;color:var(--text)">Soll (100%)</span><span>130%</span>
          </div>
        </div>
        ${cpkEst < specCpk ? `<div style="margin-top:10px;font-size:13px;color:#D93025;background:#D9302510;padding:8px 10px;border-radius:6px">⚠️ Cpk ${cpkEst.toFixed(2)} unter Ziel ${specCpk.toFixed(2)} – Einzeltoleranzen reduzieren oder Kette kürzen (siehe Beitragsanalyse nach Übernahme)</div>` : ''}
      </div>
    </div>`;
}

