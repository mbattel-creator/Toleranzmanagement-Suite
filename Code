function runMonteCarlo(){
  if(!links.length){toast('Bitte Beitragsleister unter „Kette" definieren.','error');return;}
  saveMCSpec(); // aktuelle Vorgabe übernehmen
  const runs=parseInt(document.getElementById('mc-runs').value);
  const distType=document.getElementById('mc-dist').value;
  const targetStr=document.getElementById('mc-target').value;
  const hasTarget=targetStr!=='';
  const target=hasTarget?Math.abs(parseFloat(targetStr)):null;
  const results=new Float64Array(runs);
  for(let i=0;i<runs;i++){
    let dev=0;
    for(const l of links){dev+=((l.upper+l.lower)/2)+mcSample(distType,(l.upper-l.lower)/2);}
    results[i]=dev;
  }
  const arr=Array.from(results).sort((a,b)=>a-b);
  const n2=arr.length,mean=arr.reduce((a,v)=>a+v,0)/n2;
  const s=Math.sqrt(arr.reduce((a,v)=>a+Math.pow(v-mean,2),0)/(n2-1));
  const p025=perc(arr,.025),p50=perc(arr,.5),p975=perc(arr,.975);
  // Fehlergrenze: Zieltoleranz hat Vorrang, sonst Toleranzvorgabe (chainSpec)
  let defLimit=null;
  if(hasTarget) defLimit=target;
  else if(chainSpec && chainSpec.tol>0) defLimit=chainSpec.tol;
  let defectCount=null, defectPct=null, ppm=null, qty=null, errorVehicles=null;
  if(defLimit!=null){
    defectCount=arr.filter(v=>v>defLimit||v<-defLimit).length;
    defectPct=(defectCount/n2*100);
    ppm=(defectCount/n2*1e6); // PPM = DPMO bei 1 Merkmal/Einheit
    qty=getEffectiveQty();
    if(qty&&qty>0) errorVehicles=(defectCount/n2)*qty;
  }
  const hmin=arr[0],hmax=arr[n2-1],bins=20,bw=(hmax-hmin)/bins||0.001;
  const counts=Array(bins).fill(0);
  arr.forEach(v=>{const bi=Math.min(Math.floor((v-hmin)/bw),bins-1);counts[bi]++;});
  const maxC=Math.max(...counts);
  const wcU=links.reduce((a,l)=>a+l.upper,0),wcL=links.reduce((a,l)=>a+l.lower,0);
  const midSum=links.reduce((a,l)=>a+(l.upper+l.lower)/2,0);
  const rss=Math.sqrt(links.reduce((a,l)=>{const df=l.distributionFactor||1;return a+Math.pow((l.upper-l.lower)/2*df,2);},0));
  const wcR=wcU-wcL,rssR=rss*2,mcR=p975-p025,maxR=Math.max(wcR,.001);
  const r=document.getElementById('mc-result');
  r.className='';
  r.innerHTML=`
