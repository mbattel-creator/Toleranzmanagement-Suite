function findGapReference(partA, partB){
  const a=partA.toLowerCase().replace(/\s+/g,'').replace('vorn','').replace('hinten','').replace('vorne','');
  const b=partB.toLowerCase().replace(/\s+/g,'').replace('vorn','').replace('hinten','').replace('vorne','');
  for(const [key,data] of Object.entries(GAP_REFERENCE)){
    const p=key.split('|');
    if((a.includes(p[0])||p[0].includes(a))&&(b.includes(p[1])||p[1].includes(b)))return data;
    if((b.includes(p[0])||p[0].includes(b))&&(a.includes(p[1])||p[1].includes(a)))return data;
  }
  return null;
}

