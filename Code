// Liefert {x,y,cat,interior} für ein Bauteil (exakt/normalisiert/fuzzy)
function getPartZone(name){
  if(!name) return null;
  const n=name.toLowerCase().trim();
  if(PARTS_LOOKUP[n]) return PARTS_LOOKUP[n];
  const base=n.replace(/\s*(teil\s*\d+|\d+)$/,'').trim();
  if(PARTS_LOOKUP[base]) return PARTS_LOOKUP[base];
  let best=null,bestLen=0;
  for(const k in PARTS_LOOKUP){
    if(n.includes(k)||k.includes(n)){ if(k.length>bestLen){best=PARTS_LOOKUP[k];bestLen=k.length;} }
  }
  return best;
}

