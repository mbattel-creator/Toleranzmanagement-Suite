function calcDist(){
  const vals=parseVals('dist-values');
  if(vals.length<4){toast('Bitte mindestens 4 Messwerte eingeben oder eine CSV-Datei laden.','error');return;}
  const lslStr=document.getElementById('dist-lsl').value;
  const uslStr=document.getElementById('dist-usl').value;
  const nomStr=document.getElementById('dist-nom').value;
  const hasLimits=lslStr!==''&&uslStr!=='';
  const lsl=hasLimits?parseFloat(lslStr):null;
  const usl=hasLimits?parseFloat(uslStr):null;
  const nom=nomStr!==''?parseFloat(nomStr):null;
  const n=vals.length,mean=vals.reduce((a,v)=>a+v,0)/n;
  const variance=vals.reduce((a,v)=>a+Math.pow(v-mean,2),0)/(n-1),s=Math.sqrt(variance);
  const skew=vals.reduce((a,v)=>a+Math.pow((v-mean)/s,3),0)/n;
  const kurt=vals.reduce((a,v)=>a+Math.pow((v-mean)/s,4),0)/n-3;
  const sorted=[...vals].sort((a,b)=>a-b);
  const p5=perc(sorted,.05),p50=perc(sorted,.50),p95=perc(sorted,.95);
  const normOK=Math.abs(skew)<1&&Math.abs(kurt)<2;
  const normColor=normOK?'#1DAA6A':'#F5A623';
  const hmin=sorted[0],hmax=sorted[n-1];
  const bins=Math.min(12,Math.max(6,Math.round(Math.sqrt(n))));
  const bw=(hmax-hmin)/bins||0.001;
  const counts=Array(bins).fill(0);
  vals.forEach(v=>{const bi=Math.min(Math.floor((v-hmin)/bw),bins-1);counts[bi]++;});
  const maxC=Math.max(...counts);
  const bars=counts.map((c,bi)=>{
    const xc=hmin+(bi+0.5)*bw;
    const out=hasLimits&&(xc<lsl||xc>usl);
    return `<div class="hist-bar"><div class="hist-fill" style="height:${Math.round(c/maxC*70)}px;background:${out?'#D93025':'#1A6FD4'};opacity:${(0.45+c/maxC*0.55).toFixed(2)}"></div></div>`;
  }).join('');
  const r=document.getElementById('dist-result');
  r.className='';
  r.innerHTML=`
    <div class="card">
      <div class="card-title"><svg viewBox="0 0 24 24" fill="none"><path d="M2 18C5 18 6 6 9 6C12 6 12 18 15 18C18 18 19 10 22 10" stroke="currentColor" stroke-linecap="round"/></svg>Gauß-Kurve</div>
      <canvas id="dist-gauss" height="140"></canvas>
      <div style="display:flex;gap:12px;font-size:13px;margin-top:8px;flex-wrap:wrap">
        ${hasLimits?'<span style="color:#D93025">■ Außerhalb</span><span style="color:#1DAA6A">■ In-Spec</span>':''}
        ${nom!==null?`<span style="color:#1DAA6A">— Soll: ${fmt(nom,3)}</span>`:''}
        <span style="color:#1A6FD4">— Ist x̄: ${fmt(mean,3)}</span>
      </div>
    </div>
    <div class="card">
      <div class="card-title"><svg viewBox="0 0 24 24" fill="none"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2" stroke="currentColor" stroke-linecap="round"/></svg>Statistik (n=${n})</div>
      <div class="stat-row"><span class="stat-lbl">Mittelwert x̄</span><span class="stat-val">${fmt(mean,4)}</span></div>
      <div class="stat-row"><span class="stat-lbl">Standardabw. σ</span><span class="stat-val">${fmt(s,4)}</span></div>
      ${nom!==null?`<div class="stat-row"><span class="stat-lbl">Δ Soll→Ist</span><span class="stat-val" style="color:${Math.abs(mean-nom)>s?'#D93025':'#1DAA6A'}">${fmt(mean-nom,4)}</span></div>`:''}
      <div class="stat-row"><span class="stat-lbl">Schiefe</span><span class="stat-val" style="color:${Math.abs(skew)<0.5?'#1DAA6A':'#F5A623'}">${fmt(skew,3)}</span></div>
      <div class="stat-row"><span class="stat-lbl">Kurtosis</span><span class="stat-val" style="color:${Math.abs(kurt)<1?'#1DAA6A':'#F5A623'}">${fmt(kurt,3)}</span></div>
    </div>
    <div class="card">
      <div class="card-title"><svg viewBox="0 0 24 24" fill="none"><path d="M12 2v20M2 12h20" stroke="currentColor" stroke-linecap="round" opacity=".4"/></svg>Histogramm & Perzentile</div>
      <div style="display:flex;align-items:flex-end;gap:2px;height:76px">${bars}</div>
      <div style="display:flex;justify-content:space-between;font-size:12px;color:var(--text3);margin-top:4px"><span>${fmt(hmin,3)}</span><span>${fmt(hmax,3)}</span></div>
      <div class="row3 mt8">
        <div class="metric"><div class="metric-val" style="color:var(--blue);font-size:clamp(14px,4vw,16px)">${fmt(p5,3)}</div><div class="metric-lbl">P5</div></div>
        <div class="metric"><div class="metric-val" style="color:var(--blue);font-size:clamp(14px,4vw,16px)">${fmt(p50,3)}</div><div class="metric-lbl">Median</div></div>
        <div class="metric"><div class="metric-val" style="color:var(--blue);font-size:clamp(14px,4vw,16px)">${fmt(p95,3)}</div><div class="metric-lbl">P95</div></div>
      </div>
    </div>
    <div class="card">
      <div class="banner" style="background:${normColor}18;color:${normColor}">
        <svg viewBox="0 0 24 24" fill="none" style="width:18px;height:18px;stroke:${normColor}"><path d="${normOK?'M5 12l5 5L19 7':'M12 9v4M12 17h.01'}" stroke-linecap="round" stroke-linejoin="round"/></svg>
        ${normOK?'Normalverteilung wahrscheinlich':'Normalverteilung fraglich – Shapiro-Wilk empfohlen'}
      </div>
    </div>
    <button class="btn" onclick="aiAnalyzeDist(${mean},${s},${skew},${kurt},${normOK},${n})">
      <svg viewBox="0 0 24 24" fill="none"><path d="M12 2L13.5 8.5L20 7L15.5 12L20 17L13.5 15.5L12 22L10.5 15.5L4 17L8.5 12L4 7L10.5 8.5L12 2Z" fill="currentColor"/></svg>KI-Analyse
    </button>
    <div id="dist-ai" class="hidden"></div>`;
  setTimeout(()=>{
    if(hasLimits)drawGauss('dist-gauss',mean,s,lsl,usl);
    else drawGaussNoLimits('dist-gauss',mean,s,nom);
  },50);
}

function drawGauss(canvasId,mean,s,lsl,usl){
  const canvas=document.getElementById(canvasId);if(!canvas)return;
  canvas.width=canvas.offsetWidth*2;canvas.height=280;
  const ctx=canvas.getContext('2d');
  const W=canvas.width,H=canvas.height,pad={l:40,r:40,t:34,b:44};
  const xMin=Math.min(lsl,mean-4*s)-0.3*s,xMax=Math.max(usl,mean+4*s)+0.3*s,range=xMax-xMin;
  function toX(v){return pad.l+(v-xMin)/range*(W-pad.l-pad.r);}
  function gauss(x){return Math.exp(-0.5*Math.pow((x-mean)/s,2))/(s*Math.sqrt(2*Math.PI));}
  const steps=300,dx=range/steps;
  const maxG=gauss(mean);
  function toY(g){return H-pad.b-(g/maxG)*(H-pad.t-pad.b);}
  ctx.clearRect(0,0,W,H);
  const fillGauss=(x0,x1,color)=>{
    ctx.beginPath();ctx.moveTo(toX(x0),toY(0));
    for(let i=0;i<=steps;i++){const x=xMin+i*dx;if(x>=x0&&x<=x1)ctx.lineTo(toX(x),toY(gauss(x)));}
    ctx.lineTo(toX(x1),toY(0));ctx.closePath();ctx.fillStyle=color;ctx.fill();
  };
  fillGauss(xMin,lsl,'rgba(217,48,37,0.2)');
  fillGauss(usl,xMax,'rgba(217,48,37,0.2)');
  fillGauss(lsl,usl,'rgba(29,170,106,0.15)');
  ctx.beginPath();
  for(let i=0;i<=steps;i++){const x=xMin+i*dx;i===0?ctx.moveTo(toX(x),toY(gauss(x))):ctx.lineTo(toX(x),toY(gauss(x)));}
  ctx.strokeStyle='#1A6FD4';ctx.lineWidth=3;ctx.stroke();
  const vLine=(x,color,dash)=>{ctx.beginPath();ctx.moveTo(toX(x),pad.t);ctx.lineTo(toX(x),H-pad.b);ctx.strokeStyle=color;ctx.lineWidth=2;ctx.setLineDash(dash||[]);ctx.stroke();ctx.setLineDash([]);};
  vLine(lsl,'#D93025',[6,4]);vLine(usl,'#D93025',[6,4]);vLine(mean,'#1A6FD4',[4,4]);
  const label=(x,text,color,yOff)=>{ctx.font=`bold 22px Inter,sans-serif`;ctx.fillStyle=color;ctx.textAlign='center';ctx.fillText(text,toX(x),pad.t-(yOff||10));};
  label(lsl,'UGL','#D93025');label(usl,'OGL','#D93025');label(mean,'x̄','#1A6FD4');
  ctx.font='18px JetBrains Mono,monospace';ctx.fillStyle='rgba(90,98,114,0.8)';ctx.textAlign='center';
  [lsl,mean,usl].forEach(v=>ctx.fillText(parseFloat(v).toFixed(2),toX(v),H-10));
  ctx.font='bold 18px Inter,sans-serif';ctx.fillStyle='#1DAA6A';ctx.textAlign='left';
  ctx.fillText(`Soll: ${((usl+lsl)/2).toFixed(3)}`,W*0.02,H-pad.b+22);
  ctx.fillStyle='#1A6FD4';
  ctx.fillText(`Ist: ${mean.toFixed(3)}`,W*0.02,H-pad.b+42);
}

function drawGaussNoLimits(id,mean,s,nom){
  const canvas=document.getElementById(id);if(!canvas)return;
  canvas.width=canvas.offsetWidth*2;canvas.height=280;
  const ctx=canvas.getContext('2d');
  const W=canvas.width,H=canvas.height,pad={l:40,r:40,t:34,b:44};
  const xMin=mean-4.5*s,xMax=mean+4.5*s,range=xMax-xMin;
  const maxG=gauss(mean);
  ctx.clearRect(0,0,W,H);
  ctx.beginPath();ctx.moveTo(toX(xMin),toY(0));
  for(let i=0;i<=300;i++){const x=xMin+i*(range/300);ctx.lineTo(toX(x),toY(gauss(x)));}
  ctx.lineTo(toX(xMax),toY(0));ctx.closePath();ctx.fillStyle='rgba(26,111,212,0.1)';ctx.fill();
  ctx.beginPath();
  for(let i=0;i<=300;i++){const x=xMin+i*(range/300);i===0?ctx.moveTo(toX(x),toY(gauss(x))):ctx.lineTo(toX(x),toY(gauss(x)));}
  ctx.strokeStyle='#1A6FD4';ctx.lineWidth=3;ctx.stroke();
  [-3,-2,-1,1,2,3].forEach(k=>{
    ctx.beginPath();ctx.moveTo(toX(mean+k*s),pad.t);ctx.lineTo(toX(mean+k*s),H-pad.b);
    ctx.strokeStyle=`rgba(90,98,114,${Math.abs(k)===1?0.4:0.2})`;ctx.lineWidth=1;ctx.setLineDash([3,4]);ctx.stroke();ctx.setLineDash([]);
  });
  ctx.beginPath();ctx.moveTo(toX(mean),pad.t);ctx.lineTo(toX(mean),H-pad.b);ctx.strokeStyle='#1A6FD4';ctx.lineWidth=2;ctx.setLineDash([4,4]);ctx.stroke();ctx.setLineDash([]);
  if(nom!==null){
    ctx.beginPath();ctx.moveTo(toX(nom),pad.t);ctx.lineTo(toX(nom),H-pad.b);ctx.strokeStyle='#1DAA6A';ctx.lineWidth=2;ctx.setLineDash([4,4]);ctx.stroke();ctx.setLineDash([]);
    ctx.font='bold 22px Inter,sans-serif';ctx.fillStyle='#1DAA6A';ctx.textAlign='center';ctx.fillText('Soll',toX(nom),pad.t-10);
  }
  ctx.font='bold 22px Inter,sans-serif';ctx.fillStyle='#1A6FD4';ctx.textAlign='center';ctx.fillText('x̄',toX(mean),pad.t-10);
  ctx.font='18px JetBrains Mono,monospace';ctx.fillStyle='rgba(90,98,114,0.8)';ctx.textAlign='center';
  [-2,-1,0,1,2].forEach(k=>ctx.fillText((mean+k*s).toFixed(2),toX(mean+k*s),H-10));
}

