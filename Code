// Persistenter Store (localStorage) – Struktur offen für Cloud-Sync
let store = { schema:1, app:APP_VERSION, projects:[], activeProjectId:null };
// Aktiv geladenes Projekt (Arbeitskopie, kompatibel zur bisherigen project-Variable)
let project = { id:null, name:'', qty:null, carbodyType:null, brand:'Allgemein', chains:[] };

function _uid(){ return 'p_'+Date.now().toString(36)+Math.random().toString(36).slice(2,7); }

function loadStore(){
  try{
    const raw = localStorage.getItem(STORE_KEY);
    if(raw){
      const parsed = JSON.parse(raw);
      if(parsed && parsed.projects) store = parsed;
    }
  }catch(e){ /* korrupte Daten ignorieren, frischer Store */ }
  // Aktives Projekt laden falls vorhanden
  if(store.activeProjectId){
    const p = store.projects.find(x=>x.id===store.activeProjectId);
    if(p) project = JSON.parse(JSON.stringify(p));
  }
}
function persistStore(){
  // Aktives Projekt zurück in den Store schreiben
  if(project.id){
    const idx = store.projects.findIndex(x=>x.id===project.id);
    const snapshot = JSON.parse(JSON.stringify(project));
    if(idx>=0) store.projects[idx] = snapshot; else store.projects.push(snapshot);
    store.activeProjectId = project.id;
  }
